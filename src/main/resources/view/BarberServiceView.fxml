<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.barbershop.launcher.controller.barberservice.BarberServiceController" fx:id="anchor_pane">

    <!-- Header Panel -->
    <HBox alignment="CENTER_LEFT" styleClass="header-bar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0">
        <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="20.0"/>
        </padding>
        <VBox alignment="CENTER_LEFT">
            <Label styleClass="page-title" text="Servicios de Barbería">
                <font>
                    <Font name="Roboto Bold" size="28.0"/>
                </font>
            </Label>
            <Label text="Administra los servicios que ofrece tu barbería">
                <font>
                    <Font name="Roboto Regular" size="14.0"/>
                </font>
            </Label>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox alignment="CENTER" spacing="15.0"/>
    </HBox>

    <!-- Main Content -->
    <ScrollPane fitToHeight="true" fitToWidth="true" layoutY="80.0" styleClass="content-scroll"
                AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                AnchorPane.topAnchor="80.0">
        <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="10.0"/>
        </padding>
        <VBox spacing="25.0">

            <!-- Statistics Cards -->
            <GridPane hgap="20.0" vgap="20.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="140.0" vgrow="SOMETIMES"/>
                </rowConstraints>

                <!-- Total Services -->
                <VBox styleClass="stat-card" GridPane.columnIndex="0">
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <VBox styleClass="icon-container">
                            <Region prefHeight="24.0" prefWidth="24.0"
                                    styleClass="barber-service-view-service-count-icon"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="service_count" styleClass="stat-value">
                            <font>
                                <Font name="Roboto Bold" size="32.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-label" text="Total Servicios">
                            <font>
                                <Font name="Roboto Regular" size="13.0"/>
                            </font>
                        </Label>
                    </VBox>
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="new_services_this_month_count" styleClass="stat-trend-positive">
                            <font>
                                <Font name="Roboto Medium" size="12.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-trend-label" text="nuevos este mes">
                            <font>
                                <Font name="Roboto Regular" size="11.0"/>
                            </font>
                        </Label>
                    </HBox>
                </VBox>

                <!-- Service Category count -->
                <VBox styleClass="stat-card" GridPane.columnIndex="1">
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <VBox styleClass="icon-container">
                            <Region prefHeight="24.0" prefWidth="24.0" styleClass="barber-service-view-category-icon"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="category_count" styleClass="stat-value">
                            <font>
                                <Font name="Roboto Bold" size="32.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-label" text="Cantidad de categorías">
                            <font>
                                <Font name="Roboto Regular" size="13.0"/>
                            </font>
                        </Label>
                    </VBox>
                    <HBox alignment="CENTER_LEFT" spacing="5.0" minHeight="16.0"/>
                </VBox>

                <!-- Highest and Lowest prices -->
                <VBox styleClass="stat-card" GridPane.columnIndex="2">
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <VBox styleClass="icon-container">
                            <Region prefHeight="24.0" prefWidth="24.0"
                                    styleClass="barber-service-view-highest-price-icon"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="highest_price" styleClass="stat-value">
                            <font>
                                <Font name="Roboto Bold" size="32.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-label" text="Precio más alto registrado">
                            <font>
                                <Font name="Roboto Regular" size="13.0"/>
                            </font>
                        </Label>
                    </VBox>
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="lowest_price" styleClass="stat-trend-neutral">
                            <font>
                                <Font name="Roboto Medium" size="12.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-trend-label" text="precio más bajo registrado">
                            <font>
                                <Font name="Roboto Regular" size="11.0"/>
                            </font>
                        </Label>
                    </HBox>
                </VBox>

                <!-- Average Price -->
                <VBox styleClass="stat-card" GridPane.columnIndex="3">
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <VBox styleClass="icon-container">
                            <Region prefHeight="24.0" prefWidth="24.0"
                                    styleClass="barber-service-view-average-price-icon"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="average_price" styleClass="stat-value">
                            <font>
                                <Font name="Roboto Bold" size="32.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-label" text="Precio Promedio">
                            <font>
                                <Font name="Roboto Regular" size="13.0"/>
                            </font>
                        </Label>
                    </VBox>
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="average_price_percentage_vs_last_month" styleClass="stat-trend-positive">
                            <font>
                                <Font name="Roboto Medium" size="12.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-trend-label" text="vs mes anterior">
                            <font>
                                <Font name="Roboto Regular" size="11.0"/>
                            </font>
                        </Label>
                    </HBox>
                </VBox>
                <padding>
                    <Insets bottom="20.0" top="20.0"/>
                </padding>
            </GridPane>

            <!-- Filters and Actions Section -->
            <VBox spacing="15.0">
                <Label styleClass="section-title" text="Filtros y Acciones">
                    <font>
                        <Font name="Roboto Medium" size="18.0"/>
                    </font>
                </Label>

                <VBox styleClass="filter-card">
                    <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <!-- Search -->
                        <VBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="filter-label" text="Buscar servicio">
                                <font>
                                    <Font name="Roboto Regular" size="12.0"/>
                                </font>
                            </Label>
                            <TextField fx:id="service_search_field" promptText="Nombre del servicio"
                                       styleClass="search-field"/>
                        </VBox>

                        <!-- Category Filter -->
                        <VBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="filter-label" text="Categoría">
                                <font>
                                    <Font name="Roboto Regular" size="12.0"/>
                                </font>
                            </Label>
                            <ComboBox fx:id="service_category_selector" promptText="Todas las categorías"
                                      styleClass="combo-box"/>
                        </VBox>

                        <!-- Price Range -->
                        <VBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="filter-label" text="Rango de precio">
                                <font>
                                    <Font name="Roboto Regular" size="12.0"/>
                                </font>
                            </Label>
                            <ComboBox fx:id="service_price_range_selector" promptText="Todos los precios"
                                      styleClass="combo-box"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <!-- Action Buttons -->
                        <VBox alignment="CENTER_RIGHT" spacing="8.0">
                            <Label styleClass="filter-label" text="Acciones">
                                <font>
                                    <Font name="Roboto Regular" size="12.0"/>
                                </font>
                            </Label>
                            <HBox spacing="10.0">
                                <Button fx:id="clean_filters_button" mnemonicParsing="false" styleClass="filter-button"
                                        text="Limpiar">
                                    <font>
                                        <Font name="Roboto Medium" size="13.0"/>
                                    </font>
                                </Button>
                                <Button fx:id="create_barber_service_button" mnemonicParsing="false"
                                        styleClass="action-button-primary" text="+ Nuevo Servicio">
                                    <font>
                                        <Font name="Roboto Medium" size="13.0"/>
                                    </font>
                                </Button>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Services List -->
            <VBox spacing="15.0">
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label styleClass="section-title" text="Lista de Servicios">
                        <font>
                            <Font name="Roboto Medium" size="18.0"/>
                        </font>
                    </Label>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="service_list_vbox_service_count" styleClass="results-count"
                           text="12 servicios encontrados">
                        <font>
                            <Font name="Roboto Regular" size="13.0"/>
                        </font>
                    </Label>
                </HBox>

                <!-- Services List Container -->
                <VBox fx:id="services_list_vbox" spacing="12.0">
                </VBox>
            </VBox>
        </VBox>
    </ScrollPane>
</AnchorPane>
