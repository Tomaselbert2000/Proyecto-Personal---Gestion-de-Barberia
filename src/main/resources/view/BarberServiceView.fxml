<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.*?>
<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            styleClass="md-main-content"
            fx:controller="com.barbershop.launcher.controller.implementation.barberservice.BarberServiceViewController"
            fx:id="anchor_pane">

    <VBox
            AnchorPane.topAnchor="0.0"
            AnchorPane.rightAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.bottomAnchor="0.0">

        <!-- Header Panel -->
        <HBox styleClass="md-header-bar">
            <VBox styleClass="md-heading-group">
                <Label styleClass="md-page-title" text="Servicios de Barbería"/>
                <Label text="Administra los servicios que ofrece tu barbería" styleClass="md-page-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Main Content -->
        <ScrollPane fitToHeight="true"
                    fitToWidth="true"
                    VBox.vgrow="ALWAYS"
                    styleClass="md-content-scroll">

            <VBox styleClass="md-content-section">

                <!-- Statistics Cards -->
                <GridPane styleClass="md-grid-pane">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="140.0" vgrow="SOMETIMES"/>
                    </rowConstraints>

                    <!-- Total Services -->
                    <VBox styleClass="md-card" GridPane.columnIndex="0">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="view-list-icon"/>
                                    </styleClass>
                                </Region>

                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="service_count" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Total Servicios"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="new_services_this_month_count"/>
                            <Label styleClass="md-stat-trend-label" text="nuevos este mes"/>
                        </HBox>
                    </VBox>

                    <!-- Service Category count -->
                    <VBox styleClass="md-card" GridPane.columnIndex="1">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="category-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="category_count" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Cantidad de categorías"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container"/>
                    </VBox>

                    <!-- Highest and Lowest prices -->
                    <VBox styleClass="md-card" GridPane.columnIndex="2">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="arrow-up-circle-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="highest_price" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Precio más alto registrado"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="lowest_price" styleClass="md-stat-trend-neutral"/>
                            <Label styleClass="md-stat-trend-label" text="precio más bajo registrado"/>
                        </HBox>
                    </VBox>

                    <!-- Average Price -->
                    <VBox styleClass="md-card" GridPane.columnIndex="3">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="avg-pace-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="average_price" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Precio Promedio"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="average_price_percentage_vs_last_month" styleClass="md-stat-trend-neutral"/>
                            <Label styleClass="md-stat-trend-label" text="vs mes anterior"/>
                        </HBox>
                    </VBox>
                </GridPane>

                <!-- Filters and Actions Section -->
                <VBox styleClass="md-section-group">
                    <Label styleClass="md-section-title" text="Filtros y Acciones"/>

                    <VBox styleClass="md-filter-card">
                        <HBox styleClass="md-filter-container">
                            <!-- Search -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Buscar servicio"/>
                                <MFXTextField fx:id="service_search_field"
                                              promptText="Nombre del servicio"
                                              maxWidth="Infinity"
                                              styleClass="md-mfx-input"/>
                            </VBox>

                            <!-- Category Filter -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Categoría"/>
                                <MFXComboBox fx:id="service_category_selector"
                                             maxWidth="Infinity"
                                             styleClass="md-mfx-input"/>
                            </VBox>

                            <!-- Price Range -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Rango de precio"/>
                                <MFXComboBox fx:id="service_price_range_selector"
                                             maxWidth="Infinity"
                                             styleClass="md-mfx-input"/>
                            </VBox>

                            <!-- Action Buttons -->
                            <VBox styleClass="md-filter-column">
                                <Label styleClass="md-filter-label" text="Acciones"/>
                                <HBox styleClass="md-action-button-container">

                                    <MFXButton fx:id="clean_filters_button"
                                               styleClass="md-button-outlined"
                                               text="Limpiar"/>

                                    <MFXButton fx:id="create_barber_service_button"
                                               styleClass="md-button-filled" text="+ Nuevo Servicio"/>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Services List -->
                <VBox styleClass="md-section-group">
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <Label styleClass="md-section-title" text="Lista de Servicios"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="service_list_vbox_service_count" styleClass="md-action-subtitle"/>
                    </HBox>

                    <!-- Services List Container -->
                    <VBox fx:id="services_list_vbox" styleClass="md-recent-activity-card"/>

                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
