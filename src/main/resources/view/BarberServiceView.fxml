<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="anchor_pane"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="com.launcher.controller.implementation.barberservice.BarberServiceViewController">

    <VBox
            AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <!-- Header del Panel -->
        <HBox alignment="CENTER_LEFT">
            <padding>
                <Insets top="20" right="24" bottom="12" left="24"/>
            </padding>
            <VBox spacing="2">
                <Label styleClass="md-headline-medium" text="Servicios de Barbería"/>
                <Label styleClass="md-body-large" text="Administra los servicios que ofrece tu barbería"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true" fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;"
                    VBox.vgrow="ALWAYS">
            <VBox spacing="24">
                <padding>
                    <Insets top="16" right="24" bottom="24" left="24"/>
                </padding>

                <!-- Tarjetas de Estadísticas -->
                <GridPane hgap="16" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                    </columnConstraints>

                    <!-- Tarjeta: Total Servicios -->
                    <VBox styleClass="md-card" spacing="12" GridPane.columnIndex="0">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label fx:id="service_count" styleClass="md-headline-large"/>
                                <Label styleClass="md-body-medium" text="Total Servicios"/>
                            </VBox>
                            <Region styleClass="view-list-icon, md-icon-large, md-icon-primary"/>
                        </HBox>
                        <HBox spacing="4" alignment="CENTER_LEFT">
                            <Label fx:id="new_services_this_month_count" styleClass="md-label-medium"/>
                            <Label styleClass="md-label-small" text="nuevos este mes"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Categorías -->
                    <VBox styleClass="md-card" spacing="12" GridPane.columnIndex="1">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label fx:id="category_count" styleClass="md-headline-large"/>
                                <Label styleClass="md-body-medium" text="Categorías"/>
                            </VBox>
                            <Region styleClass="category-icon, md-icon-large, md-icon-primary"/>
                        </HBox>
                        <HBox spacing="4" alignment="CENTER_LEFT"/>
                    </VBox>

                    <!-- Tarjeta: Precio más alto -->
                    <VBox styleClass="md-card" spacing="12" GridPane.columnIndex="2">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label fx:id="highest_price" styleClass="md-headline-large"/>
                                <Label styleClass="md-body-medium" text="Precio más alto"/>
                            </VBox>
                            <Region styleClass="arrow-up-circle-icon, md-icon-large, md-icon-primary"/>
                        </HBox>
                        <HBox spacing="4" alignment="CENTER_LEFT">
                            <Label fx:id="lowest_price" styleClass="md-label-medium"/>
                            <Label styleClass="md-label-small" text="precio más bajo registrado"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Precio Promedio -->
                    <VBox styleClass="md-card" spacing="12" GridPane.columnIndex="3">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label fx:id="average_price" styleClass="md-headline-large"/>
                                <Label styleClass="md-body-medium" text="Precio Promedio"/>
                            </VBox>
                            <Region styleClass="avg-pace-icon, md-icon-large, md-icon-primary"/>
                        </HBox>
                        <HBox spacing="4" alignment="CENTER_LEFT">
                            <Label fx:id="average_price_percentage_vs_last_month" styleClass="md-label-medium"/>
                            <Label styleClass="md-label-small" text="vs mes anterior"/>
                        </HBox>
                    </VBox>
                </GridPane>

                <!-- Sección de Filtros -->
                <VBox spacing="12">
                    <Label styleClass="md-title-medium" text="Filtros y Acciones"/>

                    <VBox styleClass="md-card" spacing="16">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox spacing="16">
                            <!-- Buscar servicio -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-label-medium" text="Buscar servicio"/>
                                <TextField fx:id="service_search_field"
                                           promptText="Nombre del servicio"
                                           maxWidth="Infinity"
                                           styleClass="md-text-field"/>
                            </VBox>

                            <!-- Filtro Categoría -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-label-medium" text="Categoría"/>
                                <ComboBox fx:id="service_category_selector"
                                          maxWidth="Infinity"
                                          styleClass="md-combo-box"/>
                            </VBox>

                            <!-- Filtro Rango de Precio -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-label-medium" text="Rango de precio"/>
                                <ComboBox fx:id="service_price_range_selector"
                                          maxWidth="Infinity"
                                          styleClass="md-combo-box"/>
                            </VBox>

                            <!-- Botones de Acción -->
                            <VBox spacing="4">
                                <Label styleClass="md-label-medium" text="Acciones"/>
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <MFXButton fx:id="clean_filters_button"
                                               styleClass="md-button-outlined"
                                               text="Limpiar"/>
                                    <MFXButton fx:id="create_barber_service_button"
                                               styleClass="md-button-filled" text="+ Nuevo Servicio"/>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Lista de Servicios -->
                <VBox spacing="12">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label styleClass="md-title-medium" text="Lista de Servicios"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="service_list_vbox_service_count" styleClass="md-body-small"/>
                    </HBox>

                    <VBox fx:id="services_list_vbox" styleClass="md-card">
                        <padding>
                            <Insets top="8" right="16" bottom="8" left="16"/>
                        </padding>
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
