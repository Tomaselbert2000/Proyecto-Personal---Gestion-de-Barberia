<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="anchor_pane"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="com.launcher.controller.implementation.client.ClientEditionController">

    <VBox
            AnchorPane.topAnchor="0.0"
            AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0">

        <!-- Header del Panel -->
        <HBox styleClass="md-header-bar">
            <MFXButton fx:id="back_button" styleClass="md-button-filled-tonal" text="← Volver"/>
            <VBox alignment="CENTER_LEFT">
                <Label styleClass="md-page-title" text="Editar Cliente"/>
                <Label styleClass="md-page-subtitle" text="Modifica los datos del cliente"/>
            </VBox>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="md-content-scroll" VBox.vgrow="ALWAYS">
            <VBox styleClass="md-content-section">

                <!-- Formulario de Cliente -->
                <VBox styleClass="md-card">
                    <VBox>
                        <Label styleClass="md-section-title" text="Datos Personales"/>

                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints vgrow="SOMETIMES"/>
                                <RowConstraints vgrow="SOMETIMES"/>
                                <RowConstraints vgrow="SOMETIMES"/>
                                <RowConstraints vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- DNI -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="DNI"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>

                                <TextField fx:id="dni_field" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Nombre -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Nombre"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>

                                <TextField fx:id="first_name_field" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Apellido -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Apellido"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>

                                <TextField fx:id="last_name_field" styleClass="md-text-field"/>
                            </VBox>

                            <!-- Email -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Email"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>

                                <TextField fx:id="email_field" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Teléfonos -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.columnSpan="2"
                                  GridPane.rowIndex="2">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Teléfonos"/>

                                    <MFXButton fx:id="add_phone_button" styleClass="md-button-filled-tonal"
                                               text="+ Agregar teléfono"/>
                                </HBox>

                                <!-- Contenedor de teléfonos -->
                                <VBox fx:id="phones_container" styleClass="md-section-group">
                                </VBox>
                            </VBox>

                            <!-- Estado del Cliente -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.columnSpan="2"
                                  GridPane.rowIndex="3">
                                <CheckBox fx:id="client_active_checkbox" selected="true" styleClass="md-check-box"
                                          text="Cliente activo"/>
                            </VBox>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Información Adicional -->
                <VBox styleClass="md-card">
                    <VBox styleClass="md-section-group">
                        <Label styleClass="md-section-title" text="Información Adicional"/>
                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Notas -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0"
                                  GridPane.columnSpan="2">
                                <Label styleClass="md-filter-label" text="Notas"/>
                                <TextField fx:id="optional_notes_field" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Historial del Cliente -->
                <VBox styleClass="md-card">
                    <VBox styleClass="md-section-group">
                        <Label styleClass="md-section-title" text="Historial"/>
                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Total de Visitas -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0">
                                <Label styleClass="md-page-title"/>
                                <Label styleClass="md-filter-label" text="Total Visitas"/>
                            </VBox>

                            <!-- Total Gastado -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1">
                                <Label styleClass="md-page-title"/>
                                <Label styleClass="md-filter-label" text="Total Gastado"/>
                            </VBox>

                            <!-- Última Visita -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="2">
                                <Label styleClass="md-page-title"/>
                                <Label styleClass="md-filter-label" text="Última Visita"/>
                            </VBox>

                            <!-- Cliente Desde -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="3">
                                <Label styleClass="md-page-title"/>
                                <Label styleClass="md-filter-label" text="Cliente Desde"/>
                            </VBox>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Botones de Acción -->
                <HBox styleClass="md-action-button-container">
                    <MFXButton fx:id="cancel_button" styleClass="md-button-outlined" text="Cancelar"/>
                    <MFXButton fx:id="save_button" styleClass="md-button-filled" text="Guardar Cambios"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
