<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:id="anchor_pane"
            fx:controller="com.launcher.controller.implementation.client.ClientEditionController">

    <VBox
            AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <!-- Header del Panel -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets top="20" right="24" bottom="12" left="24"/>
            </padding>
            <MFXButton fx:id="back_button" styleClass="md-button-outlined" text="← Volver"/>
            <VBox spacing="2">
                <Label styleClass="md-headline-medium" text="Editar Cliente"/>
                <Label styleClass="md-body-large" text="Modifica los datos del cliente"/>
            </VBox>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true" fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;"
                    VBox.vgrow="ALWAYS">
            <VBox spacing="24">
                <padding>
                    <Insets top="16" right="24" bottom="24" left="24"/>
                </padding>

                <!-- Formulario de Cliente -->
                <VBox styleClass="md-card" spacing="16">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <Label styleClass="md-title-medium" text="Datos Personales"/>

                    <GridPane hgap="16" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        </columnConstraints>

                        <!-- DNI -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <HBox spacing="2">
                                <Label styleClass="md-label-medium" text="DNI"/>
                                <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                            </HBox>
                            <TextField fx:id="dni_field" styleClass="md-text-field" maxWidth="Infinity"/>
                        </VBox>

                        <!-- Nombre -->
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <HBox spacing="2">
                                <Label styleClass="md-label-medium" text="Nombre"/>
                                <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                            </HBox>
                            <TextField fx:id="first_name_field" styleClass="md-text-field" maxWidth="Infinity"/>
                        </VBox>

                        <!-- Apellido -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <HBox spacing="2">
                                <Label styleClass="md-label-medium" text="Apellido"/>
                                <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                            </HBox>
                            <TextField fx:id="last_name_field" styleClass="md-text-field"/>
                        </VBox>

                        <!-- Email -->
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <HBox spacing="2">
                                <Label styleClass="md-label-medium" text="Email"/>
                                <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                            </HBox>
                            <TextField fx:id="email_field" styleClass="md-text-field" maxWidth="Infinity"/>
                        </VBox>

                        <!-- Teléfonos -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="2">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label styleClass="md-label-medium" text="Teléfonos"/>
                                <MFXButton fx:id="add_phone_button" styleClass="md-button-outlined"
                                           text="+ Agregar teléfono"/>
                            </HBox>
                            <VBox fx:id="phones_container" spacing="8"/>
                        </VBox>

                        <!-- Estado del Cliente -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="3">
                            <CheckBox fx:id="client_active_checkbox" selected="true" styleClass="md-check-box"
                                      text="Cliente activo"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Información Adicional -->
                <VBox styleClass="md-card" spacing="16">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <Label styleClass="md-title-medium" text="Información Adicional"/>

                    <GridPane hgap="16" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="100"/>
                        </columnConstraints>

                        <!-- Notas -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label styleClass="md-label-medium" text="Notas"/>
                            <TextField fx:id="optional_notes_field" styleClass="md-text-field" maxWidth="Infinity"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Historial del Cliente -->
                <VBox styleClass="md-card" spacing="16">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <Label styleClass="md-title-medium" text="Historial"/>

                    <GridPane hgap="16" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                        </columnConstraints>

                        <!-- Total de Visitas -->
                        <VBox spacing="4" GridPane.columnIndex="0">
                            <Label styleClass="md-headline-medium"/>
                            <Label styleClass="md-label-medium" text="Total Visitas"/>
                        </VBox>

                        <!-- Total Gastado -->
                        <VBox spacing="4" GridPane.columnIndex="1">
                            <Label styleClass="md-headline-medium"/>
                            <Label styleClass="md-label-medium" text="Total Gastado"/>
                        </VBox>

                        <!-- Última Visita -->
                        <VBox spacing="4" GridPane.columnIndex="2">
                            <Label styleClass="md-headline-medium"/>
                            <Label styleClass="md-label-medium" text="Última Visita"/>
                        </VBox>

                        <!-- Cliente Desde -->
                        <VBox spacing="4" GridPane.columnIndex="3">
                            <Label styleClass="md-headline-medium"/>
                            <Label styleClass="md-label-medium" text="Cliente Desde"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Botones de Acción -->
                <HBox spacing="8" alignment="CENTER_RIGHT">
                    <MFXButton fx:id="cancel_button" styleClass="md-button-outlined" text="Cancelar"/>
                    <MFXButton fx:id="save_button" styleClass="md-button-filled" text="Guardar Cambios"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
