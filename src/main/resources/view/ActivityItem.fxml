<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<HBox alignment="CENTER_LEFT"
      styleClass="md-list-item"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.barbershop.launcher.controller.implementation.dashboard.ActivityItemController">

    <!-- Icono según tipo de actividad -->
    <StackPane>
        <Region fx:id="activity_icon">
            <styleClass>
                <String fx:value="md-action-card-icon"/>
                <String fx:value=""/>
            </styleClass>
        </Region>
    </StackPane>

    <!-- Información de la actividad -->
    <VBox styleClass="md-list-item-content" HBox.hgrow="ALWAYS">

        <!-- Título de la actividad -->
        <Label fx:id="event_type" styleClass="md-list-item-title" text="Nuevo cliente registrado"/>

        <!-- Detalles adicionales -->
        <Label fx:id="text_to_attach" styleClass="md-list-item-subtitle"
               text="Juan Pérez se ha registrado en el sistema"/>
    </VBox>

    <!-- Tiempo transcurrido -->
    <VBox alignment="CENTER_RIGHT" minWidth="80.0">
        <Label fx:id="timestamp" styleClass="md-list-item-leading-text" text="Hace 5 min"/>
    </VBox>
</HBox>
