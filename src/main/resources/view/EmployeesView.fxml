<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.*?>
<AnchorPane fx:id="anchor_pane"
            styleClass="theme-barberia"
            stylesheets="@../css/material-icons.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.barbershop.launcher.controller.implementation.employee.EmployeeViewController">

    <VBox
            AnchorPane.topAnchor="0.0"
            AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0">

        <!-- Header del Panel -->
        <HBox styleClass="md-header-bar">
            <VBox styleClass="md-heading-group">
                <Label styleClass="md-page-title" text="Empleados"/>
                <Label styleClass="md-page-subtitle" text="Gestiona tu equipo de trabajo"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="15.0"/>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="md-content-scroll" VBox.vgrow="ALWAYS">
            <VBox styleClass="md-content-section">

                <!-- Tarjetas de Estadísticas -->
                <GridPane styleClass="md-grid-pane">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="140.0" vgrow="SOMETIMES"/>
                    </rowConstraints>

                    <!-- Tarjeta: Total Empleados -->
                    <VBox styleClass="md-card" GridPane.columnIndex="0">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="work-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="total_employees_count" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Total Empleados"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="total_employees_trend" styleClass="md-stat-trend-neutral"/>
                            <Label styleClass="md-stat-trend-label" text="este mes"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Empleados Activos -->
                    <VBox styleClass="md-card" GridPane.columnIndex="1">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="enterprise-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="active_employees_count" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Activos"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="active_employees_percentage" styleClass="md-stat-trend-neutral"/>
                            <Label styleClass="md-stat-trend-label" text="del equipo"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Empleados Inactivos -->
                    <VBox styleClass="md-card" GridPane.columnIndex="2">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="enterprise-off-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="inactive_employees_count" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Inactivos"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="inactive_employees_percentage" styleClass="md-stat-trend-neutral"/>
                            <Label styleClass="md-stat-trend-label" text="del equipo"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Turnos Realizados Este Mes -->
                    <VBox styleClass="md-card" GridPane.columnIndex="3">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="work-history-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="average_productivity_count" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Promedio Turnos/Mes"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="productivity_trend" styleClass="md-stat-trend-neutral"/>
                            <Label styleClass="md-stat-trend-label" text="vs mes anterior"/>
                        </HBox>
                    </VBox>
                </GridPane>

                <!-- Sección de Filtros -->
                <VBox styleClass="md-section-group">
                    <Label styleClass="md-section-title" text="Filtros y Acciones"/>

                    <VBox styleClass="md-filter-card">
                        <HBox styleClass="md-filter-container">
                            <!-- Buscador -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Buscar empleado"/>
                                <TextField fx:id="search_field" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Filtro por Estado -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Estado"/>
                                <ComboBox fx:id="status_filter" styleClass="md-combo-box" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Filtro por Fecha de Contratación -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Fecha contratación"/>
                                <ComboBox fx:id="hire_date_filter" styleClass="md-combo-box" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Botones de Acción -->
                            <VBox styleClass="md-filter-column">
                                <Label styleClass="md-filter-label" text="Acciones"/>
                                <HBox styleClass="md-action-button-container">
                                    <MFXButton fx:id="clear_filters_button" styleClass="md-button-outlined"
                                               text="Limpiar"/>
                                    <MFXButton fx:id="new_employee_button"
                                               styleClass="md-button-filled" text="+ Nuevo Empleado"/>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Lista de Empleados -->
                <VBox styleClass="md-section-group">
                    <HBox styleClass="md-section-group">
                        <Label styleClass="md-section-title" text="Lista de Empleados"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="results_count" styleClass="md-action-subtitle"/>
                    </HBox>

                    <!-- Contenedor de la Lista de Empleados -->
                    <VBox fx:id="employee_list_container" styleClass="md-recent-activity-card"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
