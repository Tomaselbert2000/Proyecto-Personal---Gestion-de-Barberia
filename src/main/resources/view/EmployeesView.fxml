                    <Font name="Roboto Regular" size="14.0" />
                </font>
            </Label>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER" spacing="15.0">
            <Button mnemonicParsing="false" styleClass="icon-button" text="_">
                <font>
                    <Font name="Roboto Regular" size="18.0" />
                </font>
            </Button>
            <Circle fill="#D4AF37" radius="20.0" stroke="#1A1A1A" strokeWidth="2.0" styleClass="user-avatar" />
        </HBox>
