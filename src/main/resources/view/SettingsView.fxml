<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane
        xmlns="http://javafx.com/javafx/25"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.barbershop.launcher.controller.implementation.settings.SettingsController">

    <fx:define>
        <ToggleGroup fx:id="themeGroup"/>
    </fx:define>

    <VBox
            AnchorPane.topAnchor="0.0"
            AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0">

        <!-- Header del Panel -->
        <HBox styleClass="md-header-bar">
            <VBox styleClass="md-heading-group">
                <Label styleClass="md-page-title" text="Configuración"/>
                <Label styleClass="md-page-subtitle" text="Administra las opciones de la aplicación"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane
                fitToHeight="true"
                fitToWidth="true"
                styleClass="md-content-scroll"
                VBox.vgrow="ALWAYS">

            <VBox styleClass="md-content-section">

                <!-- Selector de Tema -->
                <VBox styleClass="md-section-group">
                    <Label styleClass="md-section-title" text="Apariencia"/>

                    <HBox styleClass="md-card">
                        <VBox styleClass="md-heading-group">
                            <Label styleClass="md-list-item-title" text="Tema de Color"/>
                            <Label styleClass="md-filter-label" text="Selecciona el tema visual de la aplicación"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <HBox fx:id="theme_container" styleClass="md-section-group" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Configuración del Negocio -->
                <VBox styleClass="md-section-group">

                    <Label styleClass="md-section-title" text="Datos del Negocio"/>

                    <VBox styleClass="md-card">
                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints vgrow="SOMETIMES"/>
                                <RowConstraints vgrow="SOMETIMES"/>
                                <RowConstraints vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Nombre del Negocio -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label styleClass="md-filter-label" text="Nombre de la Barbería"/>
                                <TextField fx:id="name" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Teléfono -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label styleClass="md-filter-label" text="Teléfono"/>
                                <TextField fx:id="phone" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Email -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label styleClass="md-filter-label" text="Email"/>
                                <TextField fx:id="email" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Dirección -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label styleClass="md-filter-label" text="Dirección"/>
                                <TextField fx:id="address" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Horario de Apertura -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <Label styleClass="md-filter-label" text="Horario de Apertura"/>
                                <ComboBox fx:id="opening_hours" styleClass="md-combo-box"/>
                            </VBox>

                            <!-- Horario de Cierre -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                <Label styleClass="md-filter-label" text="Horario de Cierre"/>
                                <ComboBox fx:id="closing_hours" styleClass="md-combo-box"/>
                            </VBox>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Configuración de Notificaciones -->
                <VBox styleClass="md-section-group">
                    <Label styleClass="md-section-title" text="Notificaciones"/>

                    <VBox styleClass="md-card, md-section-group">
                        <HBox styleClass="md-stat-card-container">
                            <VBox styleClass="md-filter-spacer" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-list-item-title" text="Notificaciones de Turnos"/>
                                <Label styleClass="md-filter-label"
                                       text="Recibir alertas cuando se agende un nuevo turno"/>
                            </VBox>
                            <CheckBox fx:id="new_appointment_checkbox" selected="true" styleClass="md-check-box"/>
                        </HBox>

                        <Separator styleClass="md-menu-separator"/>

                        <HBox styleClass="md-stat-card-container">
                            <VBox styleClass="md-filter-spacer" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-list-item-title" text="Recordatorios de Turnos"/>
                                <Label styleClass="md-filter-label"
                                       text="Enviar recordatorios a los clientes antes de su turno"/>
                            </VBox>
                            <CheckBox fx:id="client_reminder_checkbox" selected="true" styleClass="md-check-box"/>
                        </HBox>

                        <Separator styleClass="md-menu-separator"/>

                        <HBox styleClass="md-stat-card-container">
                            <VBox styleClass="md-filter-spacer" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-list-item-title" text="Alertas de Stock"/>
                                <Label styleClass="md-filter-label"
                                       text="Notificar cuando el stock esté bajo o crítico"/>
                            </VBox>
                            <CheckBox fx:id="low_stock_checkbox" selected="true" styleClass="md-check-box"/>
                        </HBox>

                        <Separator styleClass="md-menu-separator"/>

                        <HBox styleClass="md-stat-card-container">
                            <VBox styleClass="md-filter-spacer" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-list-item-title" text="Notificaciones de Empleados"/>
                                <Label styleClass="md-filter-label"
                                       text="Alertas sobre cambios en el equipo de trabajo"/>
                            </VBox>
                            <CheckBox fx:id="workplace_changes_checkbox" selected="true" styleClass="md-check-box"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Configuración de Seguridad -->
                <VBox styleClass="md-section-group">
                    <Label styleClass="md-section-title" text="Seguridad"/>

                    <VBox styleClass="md-card">
                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints vgrow="SOMETIMES"/>
                                <RowConstraints vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Usuario Admin -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label styleClass="md-list-item-title" text="Usuario Administrador"/>
                                <TextField fx:id="user_textfield" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Cambiar Contraseña -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label styleClass="md-list-item-title" text="Nueva Contraseña"/>
                                <PasswordField fx:id="password_textfield" styleClass="md-text-field"
                                               maxWidth="Infinity"/>
                            </VBox>

                            <!-- Confirmar Contraseña -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label styleClass="md-list-item-title" text="Confirmar Contraseña"/>
                                <PasswordField fx:id="confirm_password_textfield" styleClass="md-text-field"
                                               maxWidth="Infinity"/>
                            </VBox>

                            <!-- Botón Actualizar -->
                            <VBox styleClass="md-action-button-container" GridPane.columnIndex="1"
                                  GridPane.rowIndex="1">
                                <MFXButton fx:id="update_password_button" styleClass="md-button-filled"
                                           text="Actualizar Contraseña"/>
                            </VBox>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Información de la Aplicación -->
                <VBox styleClass="md-section-group">
                    <Label styleClass="md-section-title" text="Acerca de la Aplicación"/>

                    <VBox styleClass="md-card">

                        <HBox styleClass="md-content-section">

                            <!-- Logo -->
                            <VBox alignment="CENTER" minWidth="100.0">
                                <ImageView fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true"
                                           styleClass="app-logo">
                                    <Image url="@../images/Logo.jpg"/>
                                </ImageView>
                            </VBox>

                            <!-- Información -->
                            <VBox styleClass="md-heading-group">
                                <Label styleClass="md-page-title" text="La Tercera Barbershop"/>
                                <Label styleClass="md-page-subtitle"
                                       text="Sistema de gestión integral para barberías"/>
                            </VBox>

                            <!-- Información Técnica -->
                            <GridPane styleClass="md-grid-pane" maxWidth="Infinity">
                                <Label styleClass="md-list-item-title" text="Versión:"
                                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Label fx:id="version_number" styleClass="md-list-item-title"
                                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label styleClass="md-list-item-title" text="Framework:"
                                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Label fx:id="framework_name" styleClass="md-list-item-title"
                                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <Label styleClass="md-list-item-title" text="Base de datos:"
                                       GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <Label fx:id="database_name" styleClass="md-list-item-title"
                                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                <Label styleClass="md-list-item-title" text="Fecha de compilación:"
                                       GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                <Label fx:id="compilation_timestamp" styleClass="md-list-item-title"
                                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                <Label styleClass="md-list-item-title" text="Desarrollado por:"
                                       GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                <Label fx:id="developer_name" styleClass="md-list-item-title"
                                       GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                            </GridPane>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Botones de Acción -->
                <HBox styleClass="md-action-button-container">
                    <MFXButton fx:id="cancel_button" styleClass="md-button-filled-tonal" text="Cancelar"/>
                    <MFXButton fx:id="save_button" styleClass="md-button-filled" text="Guardar Cambios"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>