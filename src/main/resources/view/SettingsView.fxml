<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="anchor_pane"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="com.launcher.controller.implementation.settings.SettingsController">

    <fx:define>
        <ToggleGroup fx:id="themeGroup"/>
    </fx:define>

    <VBox
            AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <!-- Header del Panel -->
        <HBox alignment="CENTER_LEFT">
            <padding>
                <Insets top="20" right="24" bottom="12" left="24"/>
            </padding>
            <VBox spacing="2">
                <Label styleClass="md-headline-medium" text="Configuración"/>
                <Label styleClass="md-body-large" text="Administra las opciones de la aplicación"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true" fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;"
                    VBox.vgrow="ALWAYS">
            <VBox spacing="24">
                <padding>
                    <Insets top="16" right="24" bottom="24" left="24"/>
                </padding>

                <!-- Selector de Tema -->
                <VBox spacing="12">
                    <Label styleClass="md-title-medium" text="Apariencia"/>
                    <HBox styleClass="md-card" spacing="16" alignment="CENTER_LEFT">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <VBox spacing="2">
                            <Label styleClass="md-title-large" text="Tema de Color"/>
                            <Label styleClass="md-body-small"
                                   text="Selecciona el tema visual de la aplicación"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox fx:id="theme_container" spacing="12" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Configuración del Negocio -->
                <VBox spacing="12">
                    <Label styleClass="md-title-medium" text="Datos del Negocio"/>
                    <VBox styleClass="md-card" spacing="16">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>
                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            </columnConstraints>

                            <!-- Nombre del Negocio -->
                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label styleClass="md-label-medium" text="Nombre de la Barbería"/>
                                <TextField fx:id="name" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Teléfono -->
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label styleClass="md-label-medium" text="Teléfono"/>
                                <TextField fx:id="phone" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Email -->
                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label styleClass="md-label-medium" text="Email"/>
                                <TextField fx:id="email" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Dirección -->
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label styleClass="md-label-medium" text="Dirección"/>
                                <TextField fx:id="address" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Horario de Apertura -->
                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <Label styleClass="md-label-medium" text="Horario de Apertura"/>
                                <ComboBox fx:id="opening_hours" styleClass="md-combo-box"/>
                            </VBox>

                            <!-- Horario de Cierre -->
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                <Label styleClass="md-label-medium" text="Horario de Cierre"/>
                                <ComboBox fx:id="closing_hours" styleClass="md-combo-box"/>
                            </VBox>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Configuración de Notificaciones -->
                <VBox spacing="12">
                    <Label styleClass="md-title-medium" text="Notificaciones"/>
                    <VBox styleClass="md-card">
                        <padding>
                            <Insets top="8" right="16" bottom="8" left="16"/>
                        </padding>

                        <!-- Notificación: Turnos -->
                        <HBox alignment="CENTER_LEFT" spacing="16">
                            <padding>
                                <Insets top="12" bottom="12"/>
                            </padding>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-title-medium" text="Notificaciones de Turnos"/>
                                <Label styleClass="md-body-small"
                                       text="Recibir alertas cuando se agende un nuevo turno"/>
                            </VBox>
                            <CheckBox fx:id="new_appointment_checkbox" selected="true"
                                      styleClass="md-check-box"/>
                        </HBox>

                        <Separator styleClass="md-nav-divider"/>

                        <!-- Notificación: Recordatorios -->
                        <HBox alignment="CENTER_LEFT" spacing="16">
                            <padding>
                                <Insets top="12" bottom="12"/>
                            </padding>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-title-medium" text="Recordatorios de Turnos"/>
                                <Label styleClass="md-body-small"
                                       text="Enviar recordatorios a los clientes antes de su turno"/>
                            </VBox>
                            <CheckBox fx:id="client_reminder_checkbox" selected="true"
                                      styleClass="md-check-box"/>
                        </HBox>

                        <Separator styleClass="md-nav-divider"/>

                        <!-- Notificación: Stock -->
                        <HBox alignment="CENTER_LEFT" spacing="16">
                            <padding>
                                <Insets top="12" bottom="12"/>
                            </padding>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-title-medium" text="Alertas de Stock"/>
                                <Label styleClass="md-body-small"
                                       text="Notificar cuando el stock esté bajo o crítico"/>
                            </VBox>
                            <CheckBox fx:id="low_stock_checkbox" selected="true"
                                      styleClass="md-check-box"/>
                        </HBox>

                        <Separator styleClass="md-nav-divider"/>

                        <!-- Notificación: Empleados -->
                        <HBox alignment="CENTER_LEFT" spacing="16">
                            <padding>
                                <Insets top="12" bottom="12"/>
                            </padding>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-title-medium" text="Notificaciones de Empleados"/>
                                <Label styleClass="md-body-small"
                                       text="Alertas sobre cambios en el equipo de trabajo"/>
                            </VBox>
                            <CheckBox fx:id="workplace_changes_checkbox" selected="true"
                                      styleClass="md-check-box"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Configuración de Seguridad -->
                <VBox spacing="12">
                    <Label styleClass="md-title-medium" text="Seguridad"/>
                    <HBox styleClass="md-card" spacing="24" maxWidth="Infinity">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>

                        <!-- Credenciales -->
                        <VBox spacing="12" HBox.hgrow="ALWAYS">
                            <Label styleClass="md-title-large" text="Usuario Administrador"/>
                            <TextField fx:id="user_textfield" styleClass="md-text-field"
                                       maxWidth="Infinity"/>

                            <Label styleClass="md-title-large" text="Nueva Contraseña"/>
                            <PasswordField fx:id="password_textfield" styleClass="md-text-field"
                                           maxWidth="Infinity"/>

                            <Label styleClass="md-title-large" text="Confirmar Contraseña"/>
                            <PasswordField fx:id="confirm_password_textfield" styleClass="md-text-field"
                                           maxWidth="Infinity"/>

                            <Region VBox.vgrow="ALWAYS"/>
                            <HBox alignment="CENTER_RIGHT">
                                <MFXButton fx:id="update_password_button" styleClass="md-button-filled"
                                           text="Actualizar datos"/>
                            </HBox>
                        </VBox>

                        <Separator orientation="VERTICAL" styleClass="md-nav-divider"/>

                        <!-- Generador de Contraseña -->
                        <VBox spacing="12" HBox.hgrow="ALWAYS">
                            <Label fx:id="password_length_label" styleClass="md-title-large"/>
                            <Slider fx:id="password_length_slider"/>
                            <MFXButton fx:id="suggest_strong_password" styleClass="md-button-outlined"
                                       text="Generar contraseña"/>
                            <Region VBox.vgrow="ALWAYS"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Información de la Aplicación -->
                <VBox spacing="12">
                    <Label styleClass="md-title-medium" text="Acerca de la Aplicación"/>
                    <VBox styleClass="md-card" spacing="16">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>

                        <HBox spacing="24" alignment="CENTER_LEFT">
                            <!-- Logo -->
                            <ImageView fitHeight="80.0" fitWidth="80.0" pickOnBounds="true"
                                       preserveRatio="true">
                                <Image url="@../images/Logo.jpg"/>
                            </ImageView>

                            <!-- Información -->
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-headline-medium" text="La Tercera Barbershop"/>
                                <Label styleClass="md-body-large"
                                       text="Sistema de gestión integral para barberías"/>
                            </VBox>
                        </HBox>

                        <Separator styleClass="md-nav-divider"/>

                        <!-- Información Técnica -->
                        <GridPane hgap="16" vgap="8">
                            <columnConstraints>
                                <ColumnConstraints hgrow="NEVER"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label styleClass="md-label-medium" text="Versión:"
                                   GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <Label fx:id="version_number" styleClass="md-body-medium"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                            <Label styleClass="md-label-medium" text="Framework:"
                                   GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <Label fx:id="framework_name" styleClass="md-body-medium"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                            <Label styleClass="md-label-medium" text="Base de datos:"
                                   GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <Label fx:id="database_name" styleClass="md-body-medium"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                            <Label styleClass="md-label-medium" text="Fecha de compilación:"
                                   GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                            <Label fx:id="compilation_timestamp" styleClass="md-body-medium"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                            <Label styleClass="md-label-medium" text="Desarrollado por:"
                                   GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                            <Label fx:id="developer_name" styleClass="md-body-medium"
                                   GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Botones de Acción -->
                <HBox spacing="8" alignment="CENTER_RIGHT">
                    <MFXButton fx:id="cancel_button" styleClass="md-button-text" text="Restaurar datos"/>
                    <MFXButton fx:id="save_button" styleClass="md-button-filled" text="Guardar Cambios"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
