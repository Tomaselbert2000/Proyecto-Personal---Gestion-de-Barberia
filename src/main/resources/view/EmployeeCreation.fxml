<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="anchor_pane"
            styleClass="theme-barberia"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="com.launcher.controller.implementation.employee.EmployeeCreationController">

    <VBox AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0">

        <!-- Header del Panel -->
        <HBox styleClass="md-header-bar">
            <MFXButton fx:id="back_button" styleClass="md-button-filled-tonal" text="← Volver"/>
            <VBox styleClass="md-heading-group">
                <Label styleClass="md-page-title" text="Nuevo Empleado"/>
                <Label styleClass="md-page-subtitle" text="Registra un nuevo empleado en el sistema"/>
            </VBox>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true"
                    fitToWidth="true"
                    styleClass="md-content-scroll"
                    VBox.vgrow="ALWAYS">

            <VBox styleClass="md-content-section">

                <!-- Formulario de Empleado -->
                <VBox styleClass="md-card">
                    <VBox styleClass="md-section-group">
                        <Label styleClass="md-section-title" text="Datos del Empleado"/>
                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints vgrow="SOMETIMES"/>
                                <RowConstraints vgrow="SOMETIMES"/>
                                <RowConstraints vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Nombre -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Nombre"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>
                                <TextField fx:id="first_name_field" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Apellido -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Apellido"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>
                                <TextField fx:id="last_name_field" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Fecha de Contratación -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Fecha de Contratación"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>
                                <DatePicker fx:id="hire_date_picker" styleClass="md-date-picker"/>
                            </VBox>

                            <!-- Porcentaje de Comisión -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Comisión (%)"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>
                                <TextField fx:id="commission_field" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Botones de Acción -->
                <HBox styleClass="md-action-button-container">
                    <MFXButton fx:id="clear_button" styleClass="md-button-filled-tonal" text="Limpiar datos"/>
                    <MFXButton fx:id="save_button" styleClass="md-button-filled" text="Registrar Empleado"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
