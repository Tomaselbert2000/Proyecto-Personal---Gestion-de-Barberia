<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<?import java.lang.String?>
<AnchorPane fx:id="anchor_pane" styleClass="theme-barberia" stylesheets="@../css/styles.css"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.barbershop.launcher.controller.implementation.employee.EmployeeCreationController">

    <!-- Header del Panel -->
    <HBox alignment="CENTER_LEFT" styleClass="header-bar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0">
        <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="20.0"/>
        </padding>
        <Button fx:id="back_button" mnemonicParsing="false" styleClass="back-button" text="← Volver"/>
        <VBox alignment="CENTER_LEFT">
            <Label styleClass="page-title" text="Nuevo Empleado">
                <font>
                    <Font name="Roboto Bold" size="28.0"/>
                </font>
            </Label>
            <Label text="Registra un nuevo empleado en el sistema">
                <font>
                    <Font name="Roboto Regular" size="14.0"/>
                </font>
                <styleClass>
                    <String fx:value="page-subtitle"/>
                </styleClass>
            </Label>
            <HBox.margin>
                <Insets left="15.0"/>
            </HBox.margin>
        </VBox>
    </HBox>

    <!-- Contenido Principal -->
    <ScrollPane fitToHeight="true" fitToWidth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="80.0">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="20.0"/>
        </padding>
        <VBox spacing="25.0">

            <!-- Formulario de Empleado -->
            <VBox styleClass="form-card">
                <padding>
                    <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
                </padding>
                <VBox spacing="15.0">
                    <Label styleClass="form-section-title" text="Datos del Empleado">
                        <font>
                            <Font name="Roboto Medium" size="16.0"/>
                        </font>
                    </Label>
                    <Label styleClass="form-section-subtitle" text="Ingresa los datos obligatorios del empleado">
                        <font>
                            <Font name="Roboto Regular" size="12.0"/>
                        </font>
                    </Label>

                    <GridPane hgap="25.0" vgap="20.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints vgrow="SOMETIMES"/>
                            <RowConstraints vgrow="SOMETIMES"/>
                            <RowConstraints vgrow="SOMETIMES"/>
                        </rowConstraints>

                        <!-- Nombre -->
                        <VBox alignment="CENTER_LEFT" spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <HBox spacing="5.0">
                                <Label styleClass="form-label" text="Nombre">
                                    <font>
                                        <Font name="Roboto Regular" size="13.0"/>
                                    </font>
                                </Label>
                                <Label styleClass="form-required" text="*">
                                    <font>
                                        <Font name="Roboto Bold" size="13.0"/>
                                    </font>
                                </Label>
                            </HBox>
                            <TextField fx:id="first_name_field" styleClass="form-text-field"/>
                        </VBox>

                        <!-- Apellido -->
                        <VBox alignment="CENTER_LEFT" spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <HBox spacing="5.0">
                                <Label styleClass="form-label" text="Apellido">
                                    <font>
                                        <Font name="Roboto Regular" size="13.0"/>
                                    </font>
                                </Label>
                                <Label styleClass="form-required" text="*">
                                    <font>
                                        <Font name="Roboto Bold" size="13.0"/>
                                    </font>
                                </Label>
                            </HBox>
                            <TextField fx:id="last_name_field" styleClass="form-text-field"/>
                        </VBox>

                        <!-- Fecha de Contratación -->
                        <VBox alignment="CENTER_LEFT" spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <HBox spacing="5.0">
                                <Label styleClass="form-label" text="Fecha de Contratación">
                                    <font>
                                        <Font name="Roboto Regular" size="13.0"/>
                                    </font>
                                </Label>
                                <Label styleClass="form-required" text="*">
                                    <font>
                                        <Font name="Roboto Bold" size="13.0"/>
                                    </font>
                                </Label>
                            </HBox>
                            <DatePicker fx:id="hire_date_picker" styleClass="form-date-picker" editable="false"/>
                        </VBox>

                        <!-- Porcentaje de Comisión -->
                        <VBox alignment="CENTER_LEFT" spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <HBox spacing="5.0">
                                <Label styleClass="form-label" text="Comisión (%)">
                                    <font>
                                        <Font name="Roboto Regular" size="13.0"/>
                                    </font>
                                </Label>
                                <Label styleClass="form-required" text="*">
                                    <font>
                                        <Font name="Roboto Bold" size="13.0"/>
                                    </font>
                                </Label>
                            </HBox>
                            <TextField fx:id="commission_field" styleClass="form-text-field"/>
                        </VBox>
                    </GridPane>
                </VBox>
            </VBox>

            <!-- Botones de Acción -->
            <HBox alignment="CENTER_RIGHT" spacing="15.0">
                <Button fx:id="clear_button" mnemonicParsing="false" styleClass="filter-button" text="Limpiar"/>
                <Button fx:id="save_button" mnemonicParsing="false" styleClass="action-button-primary"
                        text="Registrar Empleado"/>
            </HBox>
        </VBox>
    </ScrollPane>
</AnchorPane>
