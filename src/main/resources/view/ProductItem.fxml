<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.ImageView?>
<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.barbershop.launcher.controller.implementation.product.ProductItemController">

    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="product-card">

        <!-- Product Icon Placeholder -->
        <VBox styleClass="product-icon-container">
            <ImageView fx:id="product_image_placeholder"
                       fitWidth="50.0"
                       fitHeight="50.0"
                       preserveRatio="true"
                       styleClass="product-icon-placeholder"/>
        </VBox>

        <!-- Product Information -->
        <VBox alignment="CENTER_LEFT" spacing="4.0" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label fx:id="product_name" styleClass="product-name" text="Product Name">
                    <font>
                        <Font name="Roboto Medium" size="16.0"/>
                    </font>
                </Label>
                <VBox fx:id="stock_status_badge_vbox" styleClass="status-badge-critico">
                    <Label fx:id="stock_status_text" styleClass="status-badge-text" text="CRÍTICO">
                        <font>
                            <Font name="Roboto Bold" size="10.0"/>
                        </font>
                    </Label>
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label styleClass="product-info-label" text="Costo:">
                        <font>
                            <Font name="Roboto Regular" size="12.0"/>
                        </font>
                    </Label>
                    <Label fx:id="product_cost" styleClass="product-info-value" text="\$0.00">
                        <font>
                            <Font name="Roboto Medium" size="12.0"/>
                        </font>
                    </Label>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label styleClass="product-info-label" text="Precio:">
                        <font>
                            <Font name="Roboto Regular" size="12.0"/>
                        </font>
                    </Label>
                    <Label fx:id="product_price" styleClass="product-info-value" text="\$0.00">
                        <font>
                            <Font name="Roboto Medium" size="12.0"/>
                        </font>
                    </Label>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label styleClass="product-info-label" text="Ganancia:">
                        <font>
                            <Font name="Roboto Regular" size="12.0"/>
                        </font>
                    </Label>
                    <Label fx:id="product_profit" styleClass="product-info-value" text="0%">
                        <font>
                            <Font name="Roboto Medium" size="12.0"/>
                        </font>
                    </Label>
                </HBox>
            </HBox>
        </VBox>

        <!-- Stock Info -->
        <VBox alignment="CENTER" minWidth="100.0" styleClass="stock-container">
            <Label fx:id="current_stock" styleClass="stock-current" text="0">
                <font>
                    <Font name="Roboto Bold" size="24.0"/>
                </font>
            </Label>
            <Label styleClass="stock-label" text="en stock">
                <font>
                    <Font name="Roboto Regular" size="11.0"/>
                </font>
            </Label>
            <Label fx:id="safety_stock" styleClass="stock-safety" text="Mín: 0">
                <font>
                    <Font name="Roboto Regular" size="10.0"/>
                </font>
            </Label>
        </VBox>

        <!-- Actions -->
        <HBox alignment="CENTER" spacing="8.0">
            <Button fx:id="edit_button" mnemonicParsing="false" styleClass="appointment-action-button" text="Editar">
                <font>
                    <Font name="Roboto Medium" size="12.0"/>
                </font>
            </Button>
            <Button fx:id="add_stock_button" mnemonicParsing="false" styleClass="appointment-action-button-complete"
                    text="+ Stock">
                <font>
                    <Font name="Roboto Medium" size="12.0"/>
                </font>
            </Button>
        </HBox>

    </HBox>

</VBox>
