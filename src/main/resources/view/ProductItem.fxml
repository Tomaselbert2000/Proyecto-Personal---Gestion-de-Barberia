<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<HBox xmlns:fx="http://javafx.com/fxml/1"
      alignment="CENTER_LEFT"
      spacing="16"
      styleClass="md-list-item"
      xmlns="http://javafx.com/javafx/25"
      fx:controller="com.launcher.controller.implementation.product.ProductItemController">
    <padding>
        <Insets top="12" right="16" bottom="12" left="16"/>
    </padding>

    <!-- Product Image -->
    <ImageView fx:id="product_image_placeholder"
               fitWidth="48.0" fitHeight="48.0"
               preserveRatio="true"/>

    <!-- Product Information -->
    <VBox spacing="4" HBox.hgrow="ALWAYS">
        <!-- Name + Status -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label fx:id="product_name" styleClass="md-list-item-headline"
                   text="Product Name"/>
            <VBox fx:id="stock_status_badge_vbox">
                <Label fx:id="stock_status_text" styleClass="md-label-small"/>
            </VBox>
        </HBox>

        <!-- Details -->
        <HBox spacing="16" alignment="CENTER_LEFT">
            <HBox spacing="4">
                <Label styleClass="md-list-item-supporting-text" text="Costo:"/>
                <Label fx:id="product_cost" styleClass="md-list-item-supporting-text"/>
            </HBox>
            <HBox spacing="4">
                <Label styleClass="md-list-item-supporting-text" text="Precio:"/>
                <Label fx:id="product_price" styleClass="md-list-item-supporting-text"/>
            </HBox>
            <HBox spacing="4">
                <Label styleClass="md-list-item-supporting-text" text="Ganancia:"/>
                <Label fx:id="product_profit" styleClass="md-list-item-supporting-text"/>
            </HBox>
        </HBox>
    </VBox>

    <!-- Stock Info -->
    <VBox spacing="2" alignment="CENTER_RIGHT" minWidth="80.0">
        <Label fx:id="current_stock" styleClass="md-title-medium"/>
        <Label styleClass="md-body-small" text="en stock"/>
        <Label fx:id="safety_stock" styleClass="md-label-small"/>
    </VBox>

    <!-- Actions -->
    <HBox spacing="8" alignment="CENTER_RIGHT">
        <MFXButton fx:id="edit_button" styleClass="md-button-outlined" text="Editar"/>
        <MFXButton fx:id="add_stock_button" styleClass="md-button-filled" text="+ Stock"/>
    </HBox>
</HBox>
