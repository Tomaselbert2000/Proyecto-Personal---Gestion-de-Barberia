<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.*?>
<AnchorPane fx:id="anchor_pane"
            styleClass="md-main-content"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.barbershop.launcher.controller.implementation.appointment.AppointmentViewController">

    <VBox
            AnchorPane.topAnchor="0.0"
            AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0">

        <!-- Header Superior -->
        <HBox styleClass="md-header-bar">
            <VBox styleClass="md-heading-group">
                <Label styleClass="md-page-title" text="Gestión de Turnos"/>
                <Label styleClass="md-page-subtitle" text="Administra los turnos de tu barbería"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true"
                    fitToWidth="true"
                    VBox.vgrow="ALWAYS"
                    styleClass="md-content-scroll">

            <VBox styleClass="md-content-section">

                <!-- Tarjetas de Estadísticas de Turnos -->
                <GridPane styleClass="md-grid-pane">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="140.0" vgrow="SOMETIMES"/>
                    </rowConstraints>

                    <!-- Tarjeta: Turnos Hoy -->
                    <VBox styleClass="md-card" GridPane.columnIndex="0">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="calendar-today-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="appointments_today" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Turnos Hoy"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="completed_appointments_today"/>
                            <Label styleClass="md-stat-label" text="completados"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Programados -->
                    <VBox styleClass="md-card" GridPane.columnIndex="1">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="schedule-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="scheduled_appointments" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Programados"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="new_appointments_scheduled_today"/>
                            <Label styleClass="md-stat-trend-label" text="nuevos hoy"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Completados -->
                    <VBox styleClass="md-card" GridPane.columnIndex="2">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="done-all-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="appointments_this_month" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Este Mes"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="percentage_of_appointments_registered_vs_previous_month"/>
                            <Label styleClass="md-stat-trend-label" text="vs mes anterior"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Cancelados -->
                    <VBox styleClass="md-card" GridPane.columnIndex="3">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="person-cancel-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="canceled_appointments" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Cancelados"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="canceled_appointments_vs_past_week"/>
                            <Label styleClass="md-stat-trend-label" text="vs semana anterior"/>
                        </HBox>
                    </VBox>
                </GridPane>

                <!-- Sección de Filtros y Acciones -->
                <VBox styleClass="md-section-group">
                    <Label styleClass="md-section-title" text="Filtros y Acciones"/>

                    <VBox styleClass="md-filter-card">
                        <HBox styleClass="md-filter-container">
                            <!-- Buscador -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Buscar por cliente"/>
                                <MFXTextField fx:id="client_search_field"
                                              promptText="Nombre o apellido del cliente"
                                              maxWidth="Infinity"
                                              styleClass="md-mfx-input"/>
                            </VBox>

                            <!-- Filtro por Fecha -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Fecha"/>
                                <MFXDatePicker fx:id="date_selector"
                                               promptText="Seleccionar fecha"
                                               maxWidth="Infinity"
                                               styleClass="md-mfx-input"/>
                            </VBox>

                            <!-- Filtro por Estado -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Estado"/>
                                <MFXComboBox fx:id="appointment_status_selector"
                                             maxWidth="Infinity"
                                             styleClass="md-mfx-input"/>
                            </VBox>

                            <!-- Filtro por Empleado -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Empleado"/>
                                <MFXComboBox fx:id="employee_selector"
                                             promptText="Todos los empleados"
                                             maxWidth="Infinity"
                                             styleClass="md-mfx-input"/>
                            </VBox>

                            <!-- Botones de Acción -->
                            <VBox styleClass="md-filter-column">
                                <Label styleClass="md-filter-label" text="Acciones"/>
                                <HBox styleClass="md-action-button-container">

                                    <MFXButton fx:id="clear_filters_button"
                                               styleClass="md-button-outlined"
                                               text="Limpiar">
                                    </MFXButton>

                                    <MFXButton fx:id="register_new_appointment_button"
                                               styleClass="md-button-filled"
                                               text="+ Nuevo Turno">
                                    </MFXButton>

                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Lista de Turnos -->
                <VBox styleClass="md-section-group">
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <Label styleClass="md-section-title" text="Lista de Turnos"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="total_appointments_count" styleClass="md-action-subtitle"/>
                    </HBox>

                    <!-- Contenedor de la Lista de Turnos -->
                    <VBox fx:id="appointment_list_VBox" styleClass="md-recent-activity-card"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
