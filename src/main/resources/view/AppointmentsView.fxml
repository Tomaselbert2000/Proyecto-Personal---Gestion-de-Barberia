<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="anchor_pane"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="com.launcher.controller.implementation.appointment.AppointmentViewController">

    <VBox
            AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <!-- Header del Panel -->
        <HBox alignment="CENTER_LEFT">
            <padding>
                <Insets top="20" right="24" bottom="12" left="24"/>
            </padding>
            <VBox spacing="2">
                <Label styleClass="md-headline-medium" text="Gestión de Turnos"/>
                <Label styleClass="md-body-large" text="Administra los turnos de tu barbería"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true" fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;"
                    VBox.vgrow="ALWAYS">
            <VBox spacing="24">
                <padding>
                    <Insets top="16" right="24" bottom="24" left="24"/>
                </padding>

                <!-- Tarjetas de Estadísticas -->
                <GridPane hgap="16" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                    </columnConstraints>

                    <!-- Tarjeta: Turnos Hoy -->
                    <VBox styleClass="md-card" spacing="12" GridPane.columnIndex="0">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label fx:id="appointments_today" styleClass="md-headline-large"/>
                                <Label styleClass="md-body-medium" text="Turnos Hoy"/>
                            </VBox>
                            <Region styleClass="calendar-today-icon, md-icon-large, md-icon-primary"/>
                        </HBox>
                        <HBox spacing="4" alignment="CENTER_LEFT">
                            <Label fx:id="completed_appointments_today" styleClass="md-label-medium"/>
                            <Label styleClass="md-label-small" text="completados"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Programados -->
                    <VBox styleClass="md-card" spacing="12" GridPane.columnIndex="1">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label fx:id="scheduled_appointments" styleClass="md-headline-large"/>
                                <Label styleClass="md-body-medium" text="Programados"/>
                            </VBox>
                            <Region styleClass="schedule-icon, md-icon-large, md-icon-primary"/>
                        </HBox>
                        <HBox spacing="4" alignment="CENTER_LEFT">
                            <Label fx:id="new_appointments_scheduled_today" styleClass="md-label-medium"/>
                            <Label styleClass="md-label-small" text="nuevos hoy"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Completados -->
                    <VBox styleClass="md-card" spacing="12" GridPane.columnIndex="2">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label fx:id="appointments_this_month" styleClass="md-headline-large"/>
                                <Label styleClass="md-body-medium" text="Este Mes"/>
                            </VBox>
                            <Region styleClass="done-all-icon, md-icon-large, md-icon-primary"/>
                        </HBox>
                        <HBox spacing="4" alignment="CENTER_LEFT">
                            <Label fx:id="percentage_of_appointments_registered_vs_previous_month"
                                   styleClass="md-label-medium"/>
                            <Label styleClass="md-label-small" text="vs mes anterior"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Cancelados -->
                    <VBox styleClass="md-card" spacing="12" GridPane.columnIndex="3">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label fx:id="canceled_appointments" styleClass="md-headline-large"/>
                                <Label styleClass="md-body-medium" text="Cancelados"/>
                            </VBox>
                            <Region styleClass="person-cancel-icon, md-icon-large, md-icon-primary"/>
                        </HBox>
                        <HBox spacing="4" alignment="CENTER_LEFT">
                            <Label fx:id="canceled_appointments_vs_past_week" styleClass="md-label-medium"/>
                            <Label styleClass="md-label-small" text="vs semana anterior"/>
                        </HBox>
                    </VBox>
                </GridPane>

                <!-- Sección de Filtros -->
                <VBox spacing="12">
                    <Label styleClass="md-title-medium" text="Filtros y Acciones"/>

                    <VBox styleClass="md-card" spacing="16">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox spacing="16">
                            <!-- Buscar por cliente -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-label-medium" text="Buscar por cliente"/>
                                <TextField fx:id="client_search_field"
                                           promptText="Nombre o apellido del cliente"
                                           maxWidth="Infinity"
                                           styleClass="md-text-field"/>
                            </VBox>

                            <!-- Filtro por Fecha -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-label-medium" text="Fecha"/>
                                <DatePicker fx:id="date_selector"
                                            promptText="Seleccionar fecha"
                                            maxWidth="Infinity"
                                            styleClass="md-date-picker"/>
                            </VBox>

                            <!-- Filtro por Estado -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-label-medium" text="Estado"/>
                                <ComboBox fx:id="appointment_status_selector"
                                          maxWidth="Infinity"
                                          styleClass="md-combo-box"/>
                            </VBox>

                            <!-- Filtro por Empleado -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-label-medium" text="Empleado"/>
                                <ComboBox fx:id="employee_selector"
                                          promptText="Todos los empleados"
                                          maxWidth="Infinity"
                                          styleClass="md-combo-box"/>
                            </VBox>

                            <!-- Botones de Acción -->
                            <VBox spacing="4">
                                <Label styleClass="md-label-medium" text="Acciones"/>
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <MFXButton fx:id="clear_filters_button"
                                               styleClass="md-button-outlined"
                                               text="Limpiar"/>
                                    <MFXButton fx:id="register_new_appointment_button"
                                               styleClass="md-button-filled"
                                               text="+ Nuevo Turno"/>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Lista de Turnos -->
                <VBox spacing="12">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label styleClass="md-title-medium" text="Lista de Turnos"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="total_appointments_count" styleClass="md-body-small"/>
                    </HBox>

                    <VBox fx:id="appointment_list_VBox" styleClass="md-card">
                        <padding>
                            <Insets top="8" right="16" bottom="8" left="16"/>
                        </padding>
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
