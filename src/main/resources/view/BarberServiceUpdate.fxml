<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane fx:id="anchor_pane"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.barbershop.launcher.controller.implementation.barberservice.BarberServiceEditionController">

    <VBox AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0">

        <!-- Header Panel -->
        <HBox styleClass="md-header-bar">
            <MFXButton fx:id="back_button" styleClass="md-button-filled-tonal" text="← Volver"/>
            <VBox styleClass="md-heading-group">
                <Label styleClass="md-page-title" text="Editar Servicio"/>
                <Label styleClass="md-page-subtitle" text="Actualiza los datos del servicio seleccionado"/>
            </VBox>
        </HBox>

        <!-- Main Content -->
        <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="md-content-scroll" VBox.vgrow="ALWAYS">
            <VBox styleClass="md-content-section">

                <!-- Service Form -->
                <VBox styleClass="md-card">
                    <VBox styleClass="md-section-group">
                        <Label styleClass="md-section-title" text="Datos del Servicio"/>
                    </VBox>

                    <GridPane styleClass="md-grid-pane">
                        <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints vgrow="SOMETIMES"/>
                            <RowConstraints vgrow="SOMETIMES"/>
                            <RowConstraints vgrow="SOMETIMES"/>
                            <RowConstraints vgrow="SOMETIMES"/>
                        </rowConstraints>

                        <!-- Service ID (read-only) -->
                        <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <HBox spacing="4.0">
                                <Label styleClass="md-filter-label" text="ID del Servicio"/>
                            </HBox>
                            <MFXTextField fx:id="service_id_field" editable="false" promptText="ID del servicio"
                                          styleClass="form-text-field-disabled"/>
                        </VBox>

                        <!-- Service Name -->
                        <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <HBox spacing="4.0">
                                <Label styleClass="md-filter-label" text="Nombre del Servicio"/>
                                <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                            </HBox>
                            <MFXTextField fx:id="service_name_field" styleClass="md-mfx-input" maxWidth="Infinity"/>
                        </VBox>

                        <!-- Price -->
                        <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <HBox spacing="4.0">
                                <Label styleClass="md-filter-label" text="Precio"/>
                                <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                            </HBox>
                            <MFXTextField fx:id="price_field" styleClass="md-mfx-input"/>
                        </VBox>

                        <!-- Category -->
                        <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <HBox spacing="4.0">
                                <Label styleClass="md-filter-label" text="Categoría"/>
                                <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                            </HBox>
                            <MFXComboBox fx:id="category_combo_box" styleClass="md-mfx-input" maxWidth="Infinity"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Additional Information -->
                <VBox styleClass="md-card">
                    <VBox styleClass="md-section-group">
                        <Label styleClass="md-section-title" text="Información Adicional"/>
                    </VBox>

                    <GridPane styleClass="md-grid-pane">
                        <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints vgrow="SOMETIMES"/>
                        </rowConstraints>

                        <!-- Internal Notes -->
                        <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.columnSpan="2">
                            <Label styleClass="md-filter-label" text="Notas Internas"/>
                            <MFXTextField fx:id="internal_notes_field" styleClass="md-mfx-input"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Action Buttons -->
                <HBox styleClass="md-action-button-container">
                    <MFXButton fx:id="restore_values_button" styleClass="md-button-outlined" text="Restaurar valores"/>
                    <MFXButton fx:id="update_button" styleClass="md-button-filled" text="Actualizar Servicio"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
