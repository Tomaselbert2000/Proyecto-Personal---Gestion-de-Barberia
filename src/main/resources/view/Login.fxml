<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.launcher.controller.implementation.login.LoginController"
            fx:id="anchor_pane"
            xmlns="http://javafx.com/javafx/17.0.12">

    <VBox AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          alignment="CENTER"
          spacing="24">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Logo Placeholder Circular -->
        <StackPane>
            <Circle radius="60"
                    style="-fx-fill: -fx-surface-variant; -fx-effect: -fx-elevation-1;"/>
        </StackPane>

        <!-- Título -->
        <Label styleClass="md-headline-medium"
               text="Sistema de Gestión"
               alignment="CENTER"
               maxWidth="1.7976931348623157E308"/>

        <!-- Subtítulo -->
        <Label styleClass="md-body-large"
               text="Bienvenido de nuevo"
               alignment="CENTER"
               maxWidth="1.7976931348623157E308"/>

        <!-- Campos de entrada -->
        <VBox spacing="16"
              alignment="CENTER"
              maxWidth="350">
            <TextField fx:id="username_field"
                       styleClass="md-text-field"
                       promptText="Nombre de usuario"
                       maxWidth="1.7976931348623157E308"/>
            <PasswordField fx:id="password_field"
                           styleClass="md-text-field"
                           promptText="Contraseña"
                           maxWidth="1.7976931348623157E308"/>
        </VBox>

        <!-- Checkbox mantener sesión -->
        <CheckBox fx:id="remember_session_checkbox"
                  styleClass="md-check-box"
                  text="Mantener sesión iniciada"
                  alignment="CENTER"/>

        <MFXButton fx:id="login_button"
                   styleClass="md-button-filled"
                   text="Iniciar sesión"/>

        <!-- Texto de registro -->
        <Label styleClass="md-body-large"
               text="¿No sos usuario? Registrate"
               alignment="CENTER"
               maxWidth="1.7976931348623157E308"/>

        <!-- Botón de registro -->
        <MFXButton fx:id="register_button"
                   styleClass="md-button-outlined"
                   text="Registrarse"/>

    </VBox>
</AnchorPane>
