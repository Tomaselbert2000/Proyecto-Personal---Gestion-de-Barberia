<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.*?>
<AnchorPane fx:id="anchor_pane"
            maxHeight="1.7976931348623157E308"
            maxWidth="1.7976931348623157E308"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../css/material-icons.css"
            fx:controller="com.barbershop.launcher.controller.implementation.product.ProductViewController">

    <VBox
            AnchorPane.topAnchor="0.0"
            AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0">

        <!-- Header del Panel -->
        <HBox styleClass="md-header-bar">
            <VBox styleClass="md-heading-group">
                <Label styleClass="md-page-title" text="Stock de Productos"/>
                <Label styleClass="md-page-subtitle" text="Administra el inventario de productos"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="md-content-scroll" VBox.vgrow="ALWAYS">
            <VBox styleClass="md-content-section">

                <!-- Tarjetas de Estadísticas de Productos -->
                <GridPane styleClass="md-grid-pane">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="140.0" vgrow="SOMETIMES"/>
                    </rowConstraints>

                    <!-- Tarjeta: Total Productos -->
                    <VBox styleClass="md-card" GridPane.columnIndex="0">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="warehouse-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="product_count" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Total Productos"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="products_created_this_month" styleClass="md-stat-trend-neutral"/>
                            <Label styleClass="md-stat-trend-label" text="nuevos este mes"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Stock Crítico -->
                    <VBox styleClass="md-card" GridPane.columnIndex="1">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="exclamation-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="critical_stock_level_product_count" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Stock Crítico"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label styleClass="md-stat-trend-neutral" text="Reponer urgentemente"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Stock Bajo -->
                    <VBox styleClass="md-card" GridPane.columnIndex="2">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="stat-minus-1-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="low_stock_level_product_count" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Stock Bajo"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label styleClass="md-stat-trend-neutral" text="Revisar pronto"/>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta: Valor Total -->
                    <VBox styleClass="md-card" GridPane.columnIndex="3">
                        <HBox styleClass="md-stat-card-container">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox>
                                <Region>
                                    <styleClass>
                                        <String fx:value="md-action-card-icon"/>
                                        <String fx:value="money-bag-icon"/>
                                    </styleClass>
                                </Region>
                            </VBox>
                        </HBox>
                        <VBox styleClass="md-action-label-container">
                            <Label fx:id="total_stock_value" styleClass="md-stat-value"/>
                            <Label styleClass="md-stat-label" text="Valor en Stock"/>
                        </VBox>
                        <HBox styleClass="md-action-label-container">
                            <Label fx:id="total_stock_value_vs_last_month" styleClass="md-stat-trend-neutral"/>
                            <Label styleClass="md-stat-trend-label" text="vs mes anterior"/>
                        </HBox>
                    </VBox>
                </GridPane>

                <!-- Sección de Filtros y Acciones -->
                <VBox styleClass="md-section-group">
                    <Label styleClass="md-section-title" text="Filtros y Acciones"/>
                    <VBox styleClass="md-filter-card">
                        <HBox styleClass="md-filter-container">

                            <!-- Buscador -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Buscar producto"/>
                                <MFXTextField fx:id="product_search_field" styleClass="md-mfx-input"/>
                            </VBox>

                            <!-- Filtro por Categoría -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Categoría"/>
                                <MFXComboBox fx:id="product_category_selector" styleClass="md-mfx-input"/>
                            </VBox>

                            <!-- Filtro por Estado de Stock -->
                            <VBox styleClass="md-filter-column" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-filter-label" text="Estado de Stock"/>
                                <MFXComboBox fx:id="product_stock_status_selector" styleClass="md-mfx-input"/>
                            </VBox>

                            <!-- Botones de Acción -->
                            <VBox styleClass="md-filter-column">
                                <Label styleClass="md-filter-label" text="Acciones"/>
                                <HBox styleClass="md-action-button-container">
                                    <MFXButton fx:id="clean_filters_button"
                                               styleClass="md-button-outlined"
                                               text="Limpiar"/>

                                    <MFXButton fx:id="create_product_button"
                                               styleClass="md-button-filled"
                                               text="+ Nuevo Producto"/>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Lista de Productos -->
                <VBox styleClass="md-section-group">
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <Label styleClass="md-section-title" text="Inventario de Productos"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="products_found_count" styleClass="md-action-subtitle"/>
                    </HBox>

                    <!-- Contenedor de la Lista de Productos -->
                    <VBox fx:id="product_list_vbox" styleClass="md-recent-activity-card"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
