<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="anchor_pane" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.barbershop.launcher.controller.implementation.product.ProductViewController">

    <!-- Header del Panel -->
    <HBox alignment="CENTER_LEFT" styleClass="header-bar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0">
        <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="20.0"/>
        </padding>
        <VBox alignment="CENTER_LEFT">
            <Label styleClass="page-title" text="Stock de Productos">
                <font>
                    <Font name="Roboto Bold" size="28.0"/>
                </font>
            </Label>
            <Label text="Administra el inventario de productos">
                <font>
                    <Font name="Roboto Regular" size="14.0"/>
                </font>
                <styleClass>
                    <String fx:value="page-subtitle"/>
                </styleClass>
            </Label>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox alignment="CENTER" spacing="15.0"/>
    </HBox>

    <!-- Contenido Principal -->
    <ScrollPane fitToHeight="true" fitToWidth="true" layoutY="80.0" maxWidth="1.7976931348623157E308"
                styleClass="content-scroll" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="80.0">
        <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="10.0"/>
        </padding>
        <VBox spacing="25.0">
            <!-- Tarjetas de Estadísticas de Productos -->
            <GridPane hgap="20.0" vgap="20.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="140.0" vgrow="SOMETIMES"/>
                </rowConstraints>

                <!-- Tarjeta: Total Productos -->
                <VBox styleClass="stat-card" GridPane.columnIndex="0">
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <VBox styleClass="icon-container">
                            <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">

                            </ImageView>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="product_count" styleClass="stat-value" text="156">
                            <font>
                                <Font name="Roboto Bold" size="32.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-label" text="Total Productos">
                            <font>
                                <Font name="Roboto Regular" size="13.0"/>
                            </font>
                        </Label>
                    </VBox>
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="products_created_this_month" styleClass="stat-trend-positive" text="+12">
                            <font>
                                <Font name="Roboto Medium" size="12.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-trend-label" text="nuevos este mes">
                            <font>
                                <Font name="Roboto Regular" size="11.0"/>
                            </font>
                        </Label>
                    </HBox>
                </VBox>

                <!-- Tarjeta: Stock Crítico -->
                <VBox styleClass="stat-card" GridPane.columnIndex="1">
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <VBox styleClass="icon-container-critical">
                            <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">

                            </ImageView>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="critical_stock_level_product_count" styleClass="stat-value">
                            <font>
                                <Font name="Roboto Bold" size="32.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-label" text="Stock Crítico">
                            <font>
                                <Font name="Roboto Regular" size="13.0"/>
                            </font>
                        </Label>
                    </VBox>
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label styleClass="stat-trend-negative" text="Reponer urgentemente">
                            <font>
                                <Font name="Roboto Medium" size="12.0"/>
                            </font>
                        </Label>
                    </HBox>
                </VBox>

                <!-- Tarjeta: Stock Bajo -->
                <VBox styleClass="stat-card" GridPane.columnIndex="2">
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <VBox styleClass="icon-container-warning">
                            <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">

                            </ImageView>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="low_stock_level_product_count" styleClass="stat-value">
                            <font>
                                <Font name="Roboto Bold" size="32.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-label" text="Stock Bajo">
                            <font>
                                <Font name="Roboto Regular" size="13.0"/>
                            </font>
                        </Label>
                    </VBox>
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label styleClass="stat-trend-neutral" text="Revisar pronto">
                            <font>
                                <Font name="Roboto Medium" size="12.0"/>
                            </font>
                        </Label>
                    </HBox>
                </VBox>

                <!-- Tarjeta: Valor Total -->
                <VBox styleClass="stat-card" GridPane.columnIndex="3">
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <VBox styleClass="icon-container">
                            <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">

                            </ImageView>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="total_stock_value" styleClass="stat-value">
                            <font>
                                <Font name="Roboto Bold" size="32.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-label" text="Valor en Stock">
                            <font>
                                <Font name="Roboto Regular" size="13.0"/>
                            </font>
                        </Label>
                    </VBox>
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label fx:id="total_stock_value_vs_last_month" styleClass="stat-trend-positive">
                            <font>
                                <Font name="Roboto Medium" size="12.0"/>
                            </font>
                        </Label>
                        <Label styleClass="stat-trend-label" text="vs mes anterior">
                            <font>
                                <Font name="Roboto Regular" size="11.0"/>
                            </font>
                        </Label>
                    </HBox>
                </VBox>
            </GridPane>

            <!-- Sección de Filtros y Acciones -->
            <VBox spacing="15.0">
                <Label styleClass="section-title" text="Filtros y Acciones">
                    <font>
                        <Font name="Roboto Medium" size="18.0"/>
                    </font>
                </Label>

                <VBox styleClass="filter-card">
                    <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <!-- Buscador -->
                        <VBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="filter-label" text="Buscar producto">
                                <font>
                                    <Font name="Roboto Regular" size="12.0"/>
                                </font>
                            </Label>
                            <TextField fx:id="product_search_field" promptText="Nombre del producto"
                                       styleClass="search-field"/>
                        </VBox>

                        <!-- Filtro por Categoría -->
                        <VBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="filter-label" text="Categoría">
                                <font>
                                    <Font name="Roboto Regular" size="12.0"/>
                                </font>
                            </Label>
                            <ComboBox fx:id="product_category_selector" promptText="Todas las categorías"
                                      styleClass="combo-box"/>
                        </VBox>

                        <!-- Filtro por Estado de Stock -->
                        <VBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="filter-label" text="Estado de Stock">
                                <font>
                                    <Font name="Roboto Regular" size="12.0"/>
                                </font>
                            </Label>
                            <ComboBox fx:id="product_stock_status_selector" promptText="Todos los estados"
                                      styleClass="combo-box"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <!-- Botones de Acción -->
                        <VBox alignment="CENTER_RIGHT" spacing="8.0">
                            <Label styleClass="filter-label" text="Acciones">
                                <font>
                                    <Font name="Roboto Regular" size="12.0"/>
                                </font>
                            </Label>
                            <HBox spacing="10.0">
                                <Button fx:id="clean_filters_button" mnemonicParsing="false" styleClass="filter-button"
                                        text="Limpiar">
                                    <font>
                                        <Font name="Roboto Medium" size="13.0"/>
                                    </font>
                                </Button>
                                <Button fx:id="create_product_button" mnemonicParsing="false"
                                        styleClass="action-button-primary" text="+ Nuevo Producto">
                                    <font>
                                        <Font name="Roboto Medium" size="13.0"/>
                                    </font>
                                </Button>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Lista de Productos -->
            <VBox spacing="15.0">
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label styleClass="section-title" text="Inventario de Productos">
                        <font>
                            <Font name="Roboto Medium" size="18.0"/>
                        </font>
                    </Label>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="products_found_count" styleClass="results-count" text="156 productos encontrados">
                        <font>
                            <Font name="Roboto Regular" size="13.0"/>
                        </font>
                    </Label>
                </HBox>

                <!-- Contenedor de la Lista de Productos -->
                <VBox fx:id="product_list_vbox" spacing="12.0"/>
            </VBox>
        </VBox>
    </ScrollPane>
</AnchorPane>
