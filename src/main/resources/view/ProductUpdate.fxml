<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<AnchorPane
        fx:id="anchor_pane"
        maxHeight="1.7976931348623157E308"
        maxWidth="1.7976931348623157E308"
        xmlns="http://javafx.com/javafx/25"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.barbershop.launcher.controller.implementation.product.ProductEditionController">

    <VBox
            AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0"
            AnchorPane.topAnchor="0.0">
        <!-- Header del Panel -->

        <HBox styleClass="md-header-bar">
            <MFXButton fx:id="back_button" styleClass="md-button-filled-tonal" text="← Volver"/>
            <VBox styleClass="md-heading-group">
                <Label styleClass="md-page-title" text="Editar Producto"/>
                <Label styleClass="md-page-subtitle" text="Actualiza los datos del empleado seleccionado"/>
            </VBox>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true"
                    fitToWidth="true"
                    VBox.vgrow="ALWAYS"
                    styleClass="md-content-scroll">

            <VBox styleClass="md-content-section">

                <!-- Tarjeta de Información General -->
                <VBox styleClass="md-card">
                    <VBox styleClass="md-section-group">
                        <Label styleClass="md-filter-label" text="Información General"/>

                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                            </columnConstraints>

                            <!-- Name -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Nombre del Producto"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>
                                <MFXTextField fx:id="name" styleClass="md-mfx-input" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Brand Name -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Marca"/>
                                </HBox>
                                <MFXTextField fx:id="brand_name" styleClass="md-mfx-input" maxWidth="Infinity"/>
                            </VBox>

                            <HBox GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <!-- Category -->
                                <VBox styleClass="md-filter-column" >
                                    <HBox styleClass="md-filter-spacer">
                                        <Label styleClass="md-filter-label" text="Categoría"/>
                                        <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                    </HBox>
                                    <MFXComboBox fx:id="category" styleClass="md-mfx-input" maxWidth="Infinity"/>
                                </VBox>

                                <!-- Presentation -->
                                <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <HBox styleClass="md-filter-spacer">
                                        <Label styleClass="md-filter-label" text="Presentación"/>
                                    </HBox>
                                    <HBox styleClass="md-filter-spacer">
                                        <MFXTextField fx:id="presentation_size" styleClass="md-mfx-input"/>
                                        <MFXComboBox fx:id="presentation_unit" styleClass="md-mfx-input"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                        </GridPane>

                        <!-- Optional Description -->
                        <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.columnSpan="2"
                              GridPane.rowIndex="1">
                            <HBox styleClass="md-filter-spacer">
                                <Label styleClass="md-filter-label" text="Descripción"/>
                            </HBox>
                            <MFXTextField fx:id="optional_description" styleClass="md-mfx-input" maxWidth="Infinity"/>
                        </VBox>
                    </VBox>
                </VBox>

                <HBox styleClass="md-section-group">

                    <!-- Tarjeta de Precios y Costos -->
                    <VBox styleClass="md-card">
                        <VBox styleClass="md-section-group">
                            <Label styleClass="md-section-title" text="Precios y Costos"/>

                            <GridPane styleClass="md-grid-pane">
                                <rowConstraints>
                                    <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                                    <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                                </rowConstraints>

                                <!-- Product Cost -->
                                <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <HBox styleClass="md-filter-spacer">
                                        <Label styleClass="md-filter-label" text="Costo de Compra"/>
                                        <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                    </HBox>
                                    <MFXTextField fx:id="product_cost" styleClass="md-mfx-input"/>
                                </VBox>

                                <!-- Current Price -->
                                <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <HBox styleClass="md-filter-spacer">
                                        <Label styleClass="md-filter-label" text="Precio de Venta"/>
                                        <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                    </HBox>
                                    <MFXTextField fx:id="current_price" styleClass="md-mfx-input"/>
                                </VBox>

                                <!-- Profit Margin -->
                                <VBox styleClass="md-filter-column" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                    <HBox styleClass="md-filter-spacer">
                                        <Label styleClass="md-filter-label" text="Margen de Ganancia"/>
                                    </HBox>
                                    <HBox styleClass="md-filter-spacer">
                                        <Label fx:id="profit_margin_value" styleClass="md-filter-label"/>
                                    </HBox>
                                </VBox>

                                <!-- Product Wholesale Price -->
                                <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <HBox styleClass="md-filter-spacer">
                                        <Label styleClass="md-filter-label" text="Precio de venta por mayor"/>
                                    </HBox>
                                    <MFXTextField fx:id="product_wholesale_price" styleClass="md-mfx-input"/>
                                </VBox>

                                <!-- Min Price -->
                                <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <HBox styleClass="md-filter-spacer">
                                        <Label styleClass="md-filter-label" text="Precio de venta mínimo"/>
                                    </HBox>
                                    <MFXTextField fx:id="min_price" styleClass="md-mfx-input"/>
                                </VBox>

                                <!-- Max Discount Percentage -->
                                <VBox styleClass="md-filter-column" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                    <HBox styleClass="md-filter-spacer">
                                        <Label styleClass="md-filter-label" text="Descuento Máximo"/>
                                    </HBox>
                                    <MFXTextField fx:id="max_discount_percentage" styleClass="md-mfx-input"/>
                                </VBox>
                            </GridPane>
                        </VBox>
                    </VBox>

                    <!-- Tarjeta de Stock e Inventario -->
                    <VBox styleClass="md-card">
                        <VBox styleClass="md-section-group">
                            <Label styleClass="md-section-title" text="Stock e Inventario"/>

                            <GridPane styleClass="md-grid-pane">
                                <rowConstraints>
                                    <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                                </rowConstraints>

                                <!-- Current Stock Level -->
                                <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <HBox styleClass="md-filter-spacer">
                                        <Label styleClass="md-filter-label" text="Stock Actual"/>
                                    </HBox>
                                    <MFXTextField fx:id="current_stock_level" editable="false"
                                                  styleClass="md-mfx-input"/>
                                </VBox>

                                <!-- Safety Stock Level -->
                                <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <HBox styleClass="md-filter-spacer">
                                        <Label styleClass="md-filter-label" text="Stock Mínimo"/>
                                        <Label styleClass="form-required" text="*" style="-fx-text-fill: -fx-error"/>
                                    </HBox>
                                    <MFXTextField fx:id="safety_stock_level" styleClass="md-mfx-input"/>
                                </VBox>
                            </GridPane>
                        </VBox>
                    </VBox>

                    <!-- Tarjeta de Imagen del Producto -->
                    <VBox styleClass="md-card">
                        <VBox styleClass="md-section-group">
                            <Label styleClass="md-section-title" text="Imagen del Producto"/>

                            <HBox styleClass="md-content-section">
                                <!-- Preview de Imagen -->
                                <VBox styleClass="md-image-preview-container">
                                    <VBox styleClass="md-image-placeholder">
                                        <ImageView fx:id="product_image_preview" fitHeight="150.0" fitWidth="150.0"
                                                   pickOnBounds="true" preserveRatio="true">
                                        </ImageView>
                                    </VBox>
                                </VBox>

                                <!-- Controles de Imagen -->
                                <VBox styleClass="md-action-button-container">
                                    <MFXButton fx:id="select_image_button" styleClass="md-button-filled-tonal"
                                               text="Seleccionar Imagen"/>
                                    <MFXButton fx:id="remove_image_button" styleClass="md-button-outlined"
                                               text="Eliminar Imagen"/>
                                    <Label styleClass="md-filter-label" text="Formatos: JPG, PNG"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- Botones de Acción -->
                <HBox styleClass="md-action-button-container">
                    <MFXButton fx:id="reset_button" styleClass="md-button-filled-tonal" text="Restaurar valores"/>
                    <MFXButton fx:id="save_button" styleClass="md-button-filled" text="Actualizar datos"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
