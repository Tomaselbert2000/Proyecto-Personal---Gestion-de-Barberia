<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <VBox styleClass="client-card">
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <!-- Avatar del Cliente -->
            <VBox alignment="CENTER">
                <VBox styleClass="client-avatar-container">
                    <Label fx:id="client_initials" styleClass="client-avatar-text" text="JD">
                        <font>
                            <Font name="Roboto Bold" size="18.0"/>
                        </font>
                    </Label>
                </VBox>
            </VBox>

            <!-- Información del Cliente -->
            <VBox alignment="CENTER_LEFT" spacing="4.0" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label fx:id="client_name" styleClass="client-name" text="Juan Pérez">
                        <font>
                            <Font name="Roboto Medium" size="16.0"/>
                        </font>
                    </Label>
                    <VBox fx:id="client_status_badge" styleClass="client-status-badge-activo">
                        <Label styleClass="client-status-badge-text" text="ACTIVO">
                            <font>
                                <Font name="Roboto Bold" size="10.0"/>
                            </font>
                        </Label>
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label styleClass="client-info-label" text="DNI:">
                            <font>
                                <Font name="Roboto Regular" size="12.0"/>
                            </font>
                        </Label>
                        <Label fx:id="client_dni" styleClass="client-info-value" text="12.345.678">
                            <font>
                                <Font name="Roboto Medium" size="12.0"/>
                            </font>
                        </Label>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label styleClass="client-info-label" text="Email:">
                            <font>
                                <Font name="Roboto Regular" size="12.0"/>
                            </font>
                        </Label>
                        <Label fx:id="client_email" styleClass="client-info-value" text="juan@email.com">
                            <font>
                                <Font name="Roboto Medium" size="12.0"/>
                            </font>
                        </Label>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label styleClass="client-info-label" text="Tel:">
                            <font>
                                <Font name="Roboto Regular" size="12.0"/>
                            </font>
                        </Label>
                        <Label fx:id="client_phone" styleClass="client-info-value" text="+54 11 1234-5678">
                            <font>
                                <Font name="Roboto Medium" size="12.0"/>
                            </font>
                        </Label>
                    </HBox>
                </HBox>
            </VBox>

            <!-- Estadísticas del Cliente -->
            <VBox alignment="CENTER" minWidth="80.0">
                <Label fx:id="client_appointments_count" styleClass="client-stat-value" text="12">
                    <font>
                        <Font name="Roboto Bold" size="20.0"/>
                    </font>
                </Label>
                <Label styleClass="client-stat-label" text="visitas">
                    <font>
                        <Font name="Roboto Regular" size="11.0"/>
                    </font>
                </Label>
            </VBox>

            <!-- Última Visita -->
            <VBox alignment="CENTER" minWidth="100.0">
                <Label styleClass="client-info-label" text="Última visita">
                    <font>
                        <Font name="Roboto Regular" size="10.0"/>
                    </font>
                </Label>
                <Label fx:id="client_last_visit" styleClass="client-last-visit" text="Hace 5 días">
                    <font>
                        <Font name="Roboto Medium" size="12.0"/>
                    </font>
                </Label>
            </VBox>

            <!-- Acciones -->
            <HBox alignment="CENTER" spacing="8.0">
                <Button mnemonicParsing="false" styleClass="appointment-action-button" text="Ver">
                    <font>
                        <Font name="Roboto Medium" size="12.0"/>
                    </font>
                </Button>
                <Button mnemonicParsing="false" styleClass="appointment-action-button" text="Editar">
                    <font>
                        <Font name="Roboto Medium" size="12.0"/>
                    </font>
                </Button>
            </HBox>
        </HBox>
    </VBox>
</AnchorPane>
