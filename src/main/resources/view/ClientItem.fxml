<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<HBox xmlns:fx="http://javafx.com/fxml/1"
      alignment="CENTER_LEFT"
      spacing="16"
      styleClass="md-list-item"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="com.launcher.controller.implementation.client.ClientItemController">
    <padding>
        <Insets top="12" right="16" bottom="12" left="16"/>
    </padding>

    <!-- Client Avatar -->
    <StackPane minWidth="40.0" minHeight="40.0">
        <Label fx:id="client_initials" styleClass="md-label-large"/>
    </StackPane>

    <!-- Client Information -->
    <VBox spacing="4" HBox.hgrow="ALWAYS">
        <!-- Name + Status -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label fx:id="client_name" styleClass="md-list-item-headline"/>
            <VBox fx:id="client_status_badge">
                <Label fx:id="status_label" styleClass="md-label-small"/>
            </VBox>
        </HBox>

        <!-- Details -->
        <HBox spacing="16" alignment="CENTER_LEFT">
            <HBox spacing="4">
                <Label styleClass="md-list-item-supporting-text" text="DNI:"/>
                <Label fx:id="client_dni" styleClass="md-list-item-supporting-text"/>
            </HBox>
            <HBox spacing="4">
                <Label styleClass="md-list-item-supporting-text" text="Email:"/>
                <Label fx:id="client_email" styleClass="md-list-item-supporting-text"/>
            </HBox>
            <HBox spacing="4">
                <Label styleClass="md-list-item-supporting-text" text="Tel:"/>
                <Label fx:id="client_phone" styleClass="md-list-item-supporting-text"/>
            </HBox>
        </HBox>
    </VBox>

    <!-- Statistics -->
    <VBox alignment="CENTER" minWidth="80.0">
        <Label fx:id="client_appointments_count" styleClass="md-headline-small"/>
        <Label styleClass="md-label-small" text="visitas"/>
    </VBox>

    <!-- Last Visit -->
    <VBox alignment="CENTER" minWidth="100.0">
        <Label styleClass="md-label-small" text="Última visita"/>
        <Label fx:id="client_last_visit" styleClass="md-body-small"/>
    </VBox>

    <!-- Actions -->
    <HBox spacing="8" alignment="CENTER_RIGHT">
        <MFXButton fx:id="view_button" styleClass="md-button-outlined" text="Ver"/>
        <MFXButton fx:id="edit_button" styleClass="md-button-outlined" text="Editar"/>
    </HBox>
</HBox>
