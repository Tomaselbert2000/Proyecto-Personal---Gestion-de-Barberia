<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="anchor_pane"
            maxHeight="1.7976931348623157E308"
            maxWidth="1.7976931348623157E308"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="com.launcher.controller.implementation.appointment.AppointmentCreationController">

    <VBox AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0">

        <!-- Header del Panel -->
        <HBox styleClass="md-header-bar">

            <MFXButton fx:id="back_button" styleClass="md-button-filled-tonal" text="← Volver"/>

            <VBox styleClass="md-heading-group">
                <Label styleClass="md-page-title" text="Nuevo Turno"/>
                <Label text="Registra un nuevo turno en el sistema" styleClass="md-page-subtitle"/>
            </VBox>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="md-content-scroll">

            <VBox styleClass="md-content-section">

                <!-- Tarjeta de Cliente -->
                <VBox styleClass="md-card">
                    <VBox styleClass="md-section-group">
                        <Label styleClass="md-section-title" text="Datos del Cliente"/>

                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                                <ColumnConstraints hgrow="NEVER" minWidth="180.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Client Search -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Buscar Cliente"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>
                                <TextField fx:id="client_search_field" styleClass="md-text-field"
                                           maxWidth="Infinity"/>
                            </VBox>

                            <!-- New Client Button -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label styleClass="md-filter-label" text="¿Cliente nuevo?"/>
                                <MFXButton fx:id="create_client_button"
                                           styleClass="md-button-filled" text="+ Nuevo Cliente"/>
                            </VBox>
                        </GridPane>

                        <MFXListView fx:id="client_result_list" minHeight="150.0" prefHeight="250.0" maxWidth="Infinity"
                                     visible="false"/>

                        <!-- Selected Client Info -->
                        <VBox fx:id="selected_client_card_vbox" styleClass="md-list-item" visible="false">
                            <HBox styleClass="md-section-group">
                                <VBox alignment="CENTER" styleClass="client-avatar-container">
                                    <Label fx:id="client_initials" styleClass="md-initials"/>
                                </VBox>
                                <VBox styleClass="md-filter-spacer">
                                    <Label fx:id="client_name" styleClass="md-list-item-title"/>
                                    <Label fx:id="national_id_card_number" styleClass="md-list-item-subtitle"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <MFXButton fx:id="change_client_button" styleClass="md-button-outlined" text="Cambiar"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Tarjeta de Servicio y Empleado -->
                <VBox styleClass="md-card">
                    <VBox styleClass="md-section-group">
                        <Label styleClass="md-section-title" text="Servicio y Profesional"/>
                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Service Selection -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Servicio"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>

                                <ComboBox fx:id="barberservice_selector" styleClass="md-combo-box"
                                          maxWidth="Infinity"/>

                            </VBox>

                            <!-- Employee Selection -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Empleado asignado"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>

                                <ComboBox fx:id="employee_selector" styleClass="md-combo-box" maxWidth="Infinity"/>

                            </VBox>
                        </GridPane>

                        <!-- Service Duration Info -->
                        <VBox fx:id="service_selection_container" styleClass="md-filter-card" visible="false">
                            <HBox styleClass="md-section-group">
                                <Label styleClass="md-filter-label" text="Precio:"/>
                                <Label fx:id="service_price" styleClass="md-filter-label"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Tarjeta de Fecha y Hora -->
                <VBox styleClass="md-card">
                    <VBox styleClass="md-section-group">

                        <Label styleClass="md-section-title" text="Fecha y Hora"/>

                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Start Date -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Fecha de Inicio"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>

                                <DatePicker fx:id="date_selector" styleClass="md-date-picker" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Start Time -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Hora de Inicio"/>
                                    <Label styleClass="md-filter-label" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>

                                <ComboBox fx:id="hour_selector" styleClass="md-combo-box"/>

                            </VBox>

                            <!-- Start Minutes -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Minutos"/>
                                </HBox>
                                <ComboBox fx:id="minute_selector" styleClass="md-combo-box"/>
                            </VBox>

                            <!-- Notes -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.columnSpan="4"
                                  GridPane.rowIndex="1">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Notas (opcional)"/>
                                </HBox>
                                <TextField fx:id="appointment_notes" styleClass="md-text-field"
                                           maxWidth="Infinity" maxHeight="Infinity"/>
                            </VBox>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Tarjeta de Resumen -->
                <VBox fx:id="summary_card_vbox" styleClass="md-card" visible="false">
                    <VBox styleClass="md-content-section">
                        <Label styleClass="md-section-title" text="Resumen del Turno"/>

                        <VBox styleClass="md-section-group">
                            <HBox styleClass="md-heading-group">
                                <Label styleClass="md-list-item-subtitle" text="Cliente:"/>
                                <Label fx:id="summary_client" styleClass="md-list-item-title"/>
                            </HBox>
                            <HBox styleClass="md-heading-group">
                                <Label styleClass="md-list-item-subtitle" text="Servicio:"/>
                                <Label fx:id="summary_service" styleClass="md-list-item-title"/>
                            </HBox>
                            <HBox styleClass="md-heading-group">
                                <Label styleClass="md-list-item-subtitle" text="Profesional:"/>
                                <Label fx:id="summary_employee" styleClass="md-list-item-title"/>
                            </HBox>
                            <HBox styleClass="md-heading-group">
                                <Label styleClass="md-list-item-subtitle" text="Fecha y Hora:"/>
                                <Label fx:id="summary_datetime" styleClass="md-list-item-title"/>
                            </HBox>
                            <HBox styleClass="md-heading-group">
                                <Label styleClass="md-list-item-subtitle" text="Precio Total:"/>
                                <Label fx:id="summary_price" styleClass="md-list-item-title"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Botones de Acción -->
                <HBox styleClass="md-action-button-container">

                    <MFXButton fx:id="reset_form_button" styleClass="md-button-outlined" text="Limpiar datos"/>

                    <MFXButton fx:id="save_button" styleClass="md-button-filled"
                               text="Crear Turno"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
