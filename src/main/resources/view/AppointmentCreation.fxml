<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="anchor_pane" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.barbershop.launcher.controller.appointment.AppointmentCreationController">

    <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0">
        <!-- Header del Panel -->
        <HBox alignment="CENTER_LEFT" styleClass="header-bar">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="20.0"/>
            </padding>
            <Button fx:id="back_button" mnemonicParsing="false" styleClass="back-button" text="← Volver"/>
            <VBox alignment="CENTER_LEFT">
                <Label styleClass="page-title" text="Nuevo Turno">
                    <font>
                        <Font name="Roboto Bold" size="28.0"/>
                    </font>
                </Label>
                <Label text="Registra un nuevo turno en el sistema">
                    <font>
                        <Font name="Roboto Regular" size="14.0"/>
                    </font>
                    <styleClass>
                        <String fx:value="page-subtitle"/>
                    </styleClass>
                </Label>
                <HBox.margin>
                    <Insets left="15.0"/>
                </HBox.margin>
            </VBox>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="20.0"/>
            </padding>
            <VBox spacing="25.0">
                <!-- Tarjeta de Cliente -->
                <VBox styleClass="form-card">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
                    </padding>
                    <VBox spacing="15.0">
                        <Label styleClass="form-section-title" text="Datos del Cliente">
                            <font>
                                <Font name="Roboto Medium" size="16.0"/>
                            </font>
                        </Label>

                        <GridPane hgap="20.0" vgap="15.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                                <ColumnConstraints hgrow="NEVER" minWidth="180.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Client Search -->
                            <VBox alignment="CENTER_LEFT" spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox spacing="4.0">
                                    <Label styleClass="form-label" text="Buscar Cliente">
                                        <font>
                                            <Font name="Roboto Regular" size="13.0"/>
                                        </font>
                                    </Label>
                                    <Label styleClass="form-required" text="*">
                                        <font>
                                            <Font name="Roboto Bold" size="13.0"/>
                                        </font>
                                    </Label>
                                </HBox>
                                <HBox spacing="10.0">
                                    <TextField fx:id="client_search_field" styleClass="form-text-field"
                                               HBox.hgrow="ALWAYS">
                                        <font>
                                            <Font name="Roboto Regular" size="14.0"/>
                                        </font>
                                    </TextField>
                                </HBox>
                            </VBox>

                            <!-- New Client Button -->
                            <VBox alignment="CENTER_LEFT" spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label styleClass="form-label" text="¿Cliente nuevo?">
                                    <font>
                                        <Font name="Roboto Regular" size="13.0"/>
                                    </font>
                                </Label>
                                <Button fx:id="create_client_button" mnemonicParsing="false"
                                        styleClass="action-button-primary" text="+ Nuevo Cliente">
                                    <font>
                                        <Font name="Roboto Medium" size="13.0"/>
                                    </font>
                                </Button>
                            </VBox>
                        </GridPane>
                        <ListView fx:id="client_result_list" minHeight="150.0" prefHeight="150.0" visible="false"/>

                        <!-- Selected Client Info -->
                        <VBox fx:id="selected_client_card_vbox" styleClass="selected-client-card" visible="false">
                            <HBox alignment="CENTER_LEFT" spacing="15.0">
                                <VBox alignment="CENTER" styleClass="client-avatar-container">
                                    <Label fx:id="client_initials" styleClass="client-avatar-text">
                                        <font>
                                            <Font name="Roboto Bold" size="16.0"/>
                                        </font>
                                    </Label>
                                </VBox>
                                <VBox alignment="CENTER_LEFT" spacing="3.0">
                                    <Label fx:id="client_name" styleClass="client-name">
                                        <font>
                                            <Font name="Roboto Medium" size="15.0"/>
                                        </font>
                                    </Label>
                                    <Label fx:id="national_id_card_number" styleClass="client-info-value">
                                        <font>
                                            <Font name="Roboto Regular" size="13.0"/>
                                        </font>
                                    </Label>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="change_client_button" mnemonicParsing="false" styleClass="filter-button"
                                        text="Cambiar">
                                    <font>
                                        <Font name="Roboto Medium" size="12.0"/>
                                    </font>
                                </Button>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Tarjeta de Servicio y Empleado -->
                <VBox styleClass="form-card">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
                    </padding>
                    <VBox spacing="15.0">
                        <Label styleClass="form-section-title" text="Servicio y Profesional">
                            <font>
                                <Font name="Roboto Medium" size="16.0"/>
                            </font>
                        </Label>

                        <GridPane hgap="20.0" vgap="15.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Service Selection -->
                            <VBox alignment="CENTER_LEFT" spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox spacing="4.0">
                                    <Label styleClass="form-label" text="Servicio">
                                        <font>
                                            <Font name="Roboto Regular" size="13.0"/>
                                        </font>
                                    </Label>
                                    <Label styleClass="form-required" text="*">
                                        <font>
                                            <Font name="Roboto Bold" size="13.0"/>
                                        </font>
                                    </Label>
                                </HBox>
                                <ComboBox fx:id="barberservice_selector" styleClass="form-combo-box">
                                </ComboBox>
                            </VBox>

                            <!-- Employee Selection -->
                            <VBox alignment="CENTER_LEFT" spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox spacing="4.0">
                                    <Label styleClass="form-label" text="Profesional">
                                        <font>
                                            <Font name="Roboto Regular" size="13.0"/>
                                        </font>
                                    </Label>
                                    <Label styleClass="form-required" text="*">
                                        <font>
                                            <Font name="Roboto Bold" size="13.0"/>
                                        </font>
                                    </Label>
                                </HBox>
                                <ComboBox fx:id="employee_selector" styleClass="form-combo-box">
                                </ComboBox>
                            </VBox>
                        </GridPane>

                        <!-- Service Duration Info -->
                        <VBox fx:id="service_selection_container" styleClass="service-info-card" visible="false">
                            <HBox alignment="CENTER_LEFT" spacing="15.0">
                                <Label styleClass="service-info-label" text="Precio:">
                                    <font>
                                        <Font name="Roboto Regular" size="13.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="service_price" styleClass="service-info-value" text="\$2.500">
                                    <font>
                                        <Font name="Roboto Medium" size="14.0"/>
                                    </font>
                                </Label>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Tarjeta de Fecha y Hora -->
                <VBox styleClass="form-card">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
                    </padding>
                    <VBox spacing="15.0">
                        <Label styleClass="form-section-title" text="Fecha y Hora">
                            <font>
                                <Font name="Roboto Medium" size="16.0"/>
                            </font>
                        </Label>

                        <GridPane hgap="30.0" vgap="45.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Start Date -->
                            <VBox alignment="CENTER_LEFT" spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox spacing="4.0">
                                    <Label styleClass="form-label" text="Fecha de Inicio">
                                        <font>
                                            <Font name="Roboto Regular" size="13.0"/>
                                        </font>
                                    </Label>
                                    <Label styleClass="form-required" text="*">
                                        <font>
                                            <Font name="Roboto Bold" size="13.0"/>
                                        </font>
                                    </Label>
                                </HBox>
                                <DatePicker fx:id="date_selector" editable="false" styleClass="form-date-picker"/>
                            </VBox>

                            <!-- Start Time -->
                            <VBox alignment="CENTER_LEFT" spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox spacing="4.0">
                                    <Label styleClass="form-label" text="Hora de Inicio">
                                        <font>
                                            <Font name="Roboto Regular" size="13.0"/>
                                        </font>
                                    </Label>
                                    <Label styleClass="form-required" text="*">
                                        <font>
                                            <Font name="Roboto Bold" size="13.0"/>
                                        </font>
                                    </Label>
                                </HBox>
                                <ComboBox fx:id="hour_selector" styleClass="form-combo-box">
                                </ComboBox>
                            </VBox>

                            <!-- Start Minutes -->
                            <VBox alignment="CENTER_LEFT" spacing="5.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <HBox spacing="4.0">
                                    <Label styleClass="form-label" text="Minutos">
                                        <font>
                                            <Font name="Roboto Regular" size="13.0"/>
                                        </font>
                                    </Label>
                                </HBox>
                                <ComboBox fx:id="minute_selector" styleClass="form-combo-box">
                                </ComboBox>
                            </VBox>

                            <!-- Notes -->
                            <VBox alignment="CENTER_LEFT" spacing="5.0" GridPane.columnIndex="0" GridPane.columnSpan="4"
                                  GridPane.rowIndex="1">
                                <HBox spacing="4.0">
                                    <Label styleClass="form-label" text="Notas (opcional)">
                                        <font>
                                            <Font name="Roboto Regular" size="13.0"/>
                                        </font>
                                    </Label>
                                </HBox>
                                <TextField fx:id="appointment_notes" styleClass="form-text-field-notes">
                                    <font>
                                        <Font name="Roboto Regular" size="14.0"/>
                                    </font>
                                </TextField>
                            </VBox>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                            </padding>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Tarjeta de Resumen -->
                <VBox spacing="-Infinity" styleClass="appointment-summary-card" visible="false">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
                    </padding>
                    <VBox spacing="15.0">
                        <Label styleClass="form-section-title" text="Resumen del Turno">
                            <font>
                                <Font name="Roboto Medium" size="16.0"/>
                            </font>
                        </Label>

                        <VBox spacing="12.0">
                            <HBox alignment="CENTER_LEFT" spacing="20.0">
                                <Label styleClass="summary-label" text="Cliente:">
                                    <font>
                                        <Font name="Roboto Regular" size="14.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="summary_client" styleClass="summary-value" text="-">
                                    <font>
                                        <Font name="Roboto Medium" size="14.0"/>
                                    </font>
                                </Label>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="20.0">
                                <Label styleClass="summary-label" text="Servicio:">
                                    <font>
                                        <Font name="Roboto Regular" size="14.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="summary_service" styleClass="summary-value" text="-">
                                    <font>
                                        <Font name="Roboto Medium" size="14.0"/>
                                    </font>
                                </Label>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="20.0">
                                <Label styleClass="summary-label" text="Profesional:">
                                    <font>
                                        <Font name="Roboto Regular" size="14.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="summary_employee" styleClass="summary-value" text="-">
                                    <font>
                                        <Font name="Roboto Medium" size="14.0"/>
                                    </font>
                                </Label>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="20.0">
                                <Label styleClass="summary-label" text="Fecha y Hora:">
                                    <font>
                                        <Font name="Roboto Regular" size="14.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="summary_datetime" styleClass="summary-value" text="-">
                                    <font>
                                        <Font name="Roboto Medium" size="14.0"/>
                                    </font>
                                </Label>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="20.0">
                                <Label styleClass="summary-label" text="Precio Total:">
                                    <font>
                                        <Font name="Roboto Regular" size="14.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="summary_price" styleClass="summary-price" text="\$0.00">
                                    <font>
                                        <Font name="Roboto Bold" size="16.0"/>
                                    </font>
                                </Label>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Botones de Acción -->
                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <Button fx:id="save_button" mnemonicParsing="false" styleClass="action-button-primary"
                            text="Crear Turno">
                        <font>
                            <Font name="Roboto Medium" size="14.0"/>
                        </font>
                    </Button>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
