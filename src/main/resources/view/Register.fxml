<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="anchor_pane"
            fx:controller="com.launcher.controller.implementation.register.RegisterController"
            xmlns="http://javafx.com/javafx/17.0.12">

    <VBox
            AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <!-- Header del Panel -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets top="20" right="24" bottom="12" left="24"/>
            </padding>
            <MFXButton fx:id="back_button" styleClass="md-button-outlined" text="← Volver"/>
            <VBox spacing="2">
                <Label styleClass="md-headline-medium" text="Crear cuenta"/>
                <Label styleClass="md-body-large" text="Registra un nuevo usuario en el sistema"/>
            </VBox>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true" fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;"
                    VBox.vgrow="ALWAYS">

            <VBox alignment="CENTER"
                  spacing="24"
                  VBox.vgrow="ALWAYS"
                  maxWidth="1.7976931348623157E308"
                  minWidth="320">
                <padding>
                    <Insets top="16" right="24" bottom="24" left="24"/>
                </padding>

                <VBox alignment="CENTER"
                      spacing="24"
                      maxWidth="400"
                      minWidth="280"
                      VBox.vgrow="ALWAYS">

                    <VBox styleClass="md-card" spacing="16" maxWidth="1.7976931348623157E308">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>

                        <VBox spacing="4" maxWidth="1.7976931348623157E308">
                            <HBox spacing="2">
                                <Label styleClass="md-label-medium" text="Nombre de usuario"/>
                                <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                            </HBox>
                            <TextField fx:id="username_field"
                                       styleClass="md-text-field"
                                       promptText="Ingresá tu nombre de usuario"
                                       maxWidth="1.7976931348623157E308"
                                       minWidth="200"/>
                        </VBox>

                        <VBox spacing="4" maxWidth="1.7976931348623157E308">
                            <HBox spacing="2">
                                <Label styleClass="md-label-medium" text="Contraseña"/>
                                <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                            </HBox>
                            <PasswordField fx:id="password_field"
                                           styleClass="md-text-field"
                                           promptText="Ingresá tu contraseña"
                                           maxWidth="1.7976931348623157E308"
                                           minWidth="200"/>
                        </VBox>

                        <VBox spacing="4" maxWidth="1.7976931348623157E308">
                            <HBox spacing="2">
                                <Label styleClass="md-label-medium" text="Confirmar contraseña"/>
                                <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                            </HBox>
                            <PasswordField fx:id="confirm_password_field"
                                           styleClass="md-text-field"
                                           promptText="Repetí tu contraseña"
                                           maxWidth="1.7976931348623157E308"
                                           minWidth="200"/>
                        </VBox>

                    </VBox>

                    <MFXButton fx:id="create_user_button"
                               maxWidth="1.7976931348623157E308"
                               minWidth="200"
                               styleClass="md-button-filled"
                               text="Crear usuario"/>

                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
