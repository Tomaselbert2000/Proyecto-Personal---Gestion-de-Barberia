<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="anchor_pane"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="com.launcher.controller.implementation.product.ProductCreationController">

    <VBox
            AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <!-- Header del Panel -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <padding>
                <Insets top="20" right="24" bottom="12" left="24"/>
            </padding>
            <MFXButton fx:id="back_button" styleClass="md-button-outlined" text="Volver"/>
            <VBox spacing="2">
                <Label styleClass="md-headline-medium" text="Nuevo Producto"/>
                <Label styleClass="md-body-large" text="Agrega un nuevo producto al inventario"/>
            </VBox>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true" fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;"
                    VBox.vgrow="ALWAYS">
            <VBox spacing="24">
                <padding>
                    <Insets top="16" right="24" bottom="24" left="24"/>
                </padding>

                <!-- Tarjeta de Información General -->
                <VBox styleClass="md-card" spacing="16">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <Label styleClass="md-title-medium" text="Información General"/>

                    <GridPane hgap="16" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        </columnConstraints>

                        <!-- Nombre del Producto -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <HBox spacing="4">
                                <Label styleClass="md-label-medium" text="Nombre del Producto"/>
                                <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                            </HBox>
                            <TextField fx:id="name" styleClass="md-text-field" maxWidth="Infinity"/>
                        </VBox>

                        <!-- Categoría -->
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <HBox spacing="4">
                                <Label styleClass="md-label-medium" text="Categoría"/>
                                <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                            </HBox>
                            <ComboBox fx:id="product_category_selector" styleClass="md-combo-box"
                                      maxWidth="Infinity"/>
                        </VBox>

                        <!-- Descripción -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.columnSpan="2"
                              GridPane.rowIndex="1">
                            <Label styleClass="md-label-medium" text="Descripción"/>
                            <TextField fx:id="optional_description" styleClass="md-text-field"
                                       maxWidth="Infinity"/>
                        </VBox>

                        <!-- Marca -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label styleClass="md-label-medium" text="Marca"/>
                            <TextField fx:id="brand_name" styleClass="md-text-field" maxWidth="Infinity"/>
                        </VBox>

                        <!-- Presentación -->
                        <HBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label styleClass="md-label-medium" text="Presentación"/>
                                <TextField fx:id="product_presentation_field" styleClass="md-text-field"
                                           maxWidth="Infinity"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label styleClass="md-label-medium" text="Unidad"/>
                                <ComboBox fx:id="presentation_unit_combobox" styleClass="md-combo-box"/>
                            </VBox>
                        </HBox>
                    </GridPane>
                </VBox>

                <!-- Fila: Precios, Stock e Imagen -->
                <HBox spacing="16">

                    <!-- Tarjeta de Precios y Costos -->
                    <VBox styleClass="md-card" spacing="16" HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>

                        <Label styleClass="md-title-medium" text="Precios y Costos"/>

                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="33"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="33"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="33"/>
                            </columnConstraints>

                            <!-- Costo de Compra -->
                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox spacing="4">
                                    <Label styleClass="md-label-medium" text="Costo de Compra"/>
                                    <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>
                                <TextField fx:id="cost" styleClass="md-text-field"/>
                            </VBox>

                            <!-- Precio de Venta -->
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox spacing="4">
                                    <Label styleClass="md-label-medium" text="Precio de Venta"/>
                                    <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>
                                <TextField fx:id="current_price" styleClass="md-text-field"/>
                            </VBox>

                            <!-- Margen de Ganancia -->
                            <VBox spacing="4" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label styleClass="md-label-medium" text="Margen de Ganancia"/>
                                <Label fx:id="profit_margin_value" styleClass="md-body-medium"/>
                            </VBox>

                            <!-- Precio Mayoreo -->
                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label styleClass="md-label-medium" text="Precio de venta por mayor"/>
                                <TextField fx:id="wholesale_price" styleClass="md-text-field"/>
                            </VBox>

                            <!-- Precio Mínimo -->
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label styleClass="md-label-medium" text="Precio de venta mínimo"/>
                                <TextField fx:id="min_price" styleClass="md-text-field"/>
                            </VBox>

                            <!-- Descuento Máximo -->
                            <VBox spacing="4" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                <Label styleClass="md-label-medium" text="Descuento Máximo"/>
                                <TextField fx:id="max_discount" styleClass="md-text-field"/>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- Tarjeta de Stock e Inventario -->
                    <VBox styleClass="md-card" spacing="16" HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>

                        <Label styleClass="md-title-medium" text="Stock e Inventario"/>

                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            </columnConstraints>

                            <!-- Stock Inicial -->
                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox spacing="4">
                                    <Label styleClass="md-label-medium" text="Stock Inicial"/>
                                    <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>
                                <TextField fx:id="current_stock_level" styleClass="md-text-field"/>
                            </VBox>

                            <!-- Stock Mínimo -->
                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox spacing="4">
                                    <Label styleClass="md-label-medium" text="Stock Mínimo"/>
                                    <Label styleClass="md-label-medium" text="*" style="-fx-text-fill: -fx-error"/>
                                </HBox>
                                <TextField fx:id="safety_stock_level" styleClass="md-text-field"/>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- Tarjeta de Imagen del Producto -->
                    <VBox styleClass="md-card" spacing="16">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>

                        <Label styleClass="md-title-medium" text="Imagen del Producto"/>

                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <ImageView fx:id="product_image_preview"
                                       fitHeight="120.0" fitWidth="120.0"
                                       pickOnBounds="true" preserveRatio="true"/>

                            <VBox spacing="8">
                                <MFXButton fx:id="select_image_button" styleClass="md-button-outlined"
                                           text="Seleccionar Imagen"/>
                                <MFXButton fx:id="remove_image_button" styleClass="md-button-text"
                                           text="Eliminar Imagen"/>
                                <Label styleClass="md-body-small" text="Formatos: JPG, PNG"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Botones de Acción -->
                <HBox spacing="8" alignment="CENTER_RIGHT">
                    <MFXButton fx:id="reset_form_button" styleClass="md-button-text" text="Limpiar campos"/>
                    <MFXButton fx:id="save_button" styleClass="md-button-filled" text="Guardar Producto"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
