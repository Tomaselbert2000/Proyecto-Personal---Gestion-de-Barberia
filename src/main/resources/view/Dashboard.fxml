<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import java.lang.*?>
<BorderPane fx:id="borderPane" prefHeight="720" prefWidth="1200" styleClass="md-main-content"
            stylesheets="@../css/design-system.css" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.barbershop.launcher.controller.implementation.dashboard.DashboardController">

    <left>
        <VBox styleClass="md-sidebar">

            <!-- Logo y Nombre -->
            <VBox alignment="CENTER" styleClass="md-logo-section">
                <ImageView fitHeight="70.0" fitWidth="70.0" pickOnBounds="true" preserveRatio="true"
                           styleClass="logo-image">
                    <Image url="@../images/Logo.jpg"/>
                </ImageView>
                <Label styleClass="md-brand-title" text="LA TERCERA"/>
                <Label styleClass="md-brand-subtitle" text="BARBERSHOP"/>
            </VBox>

            <Separator styleClass="md-menu-separator"/>

            <!-- Menú de Navegación -->
            <VBox VBox.vgrow="ALWAYS" styleClass="md-navbar-button-container">

                <MFXButton fx:id="navbar_dashboard_button" maxWidth="Infinity" styleClass="md-nav-button"
                           text="Dashboard">
                </MFXButton>

                <MFXButton fx:id="navbar_client_button" maxWidth="Infinity" styleClass="md-nav-button" text="Clientes">
                </MFXButton>

                <MFXButton fx:id="navbar_employee_button" maxWidth="Infinity" styleClass="md-nav-button"
                           text="Empleados">
                </MFXButton>

                <MFXButton fx:id="navbar_appointment_button" maxWidth="Infinity" styleClass="md-nav-button"
                           text="Turnos">
                </MFXButton>

                <MFXButton fx:id="navbar_barber_service_button" maxWidth="Infinity" styleClass="md-nav-button"
                           text="Servicios">
                </MFXButton>

                <MFXButton fx:id="navbar_product_button" maxWidth="Infinity" styleClass="md-nav-button"
                           text="Stock de productos">
                </MFXButton>
            </VBox>

            <Separator styleClass="md-menu-separator"/>

            <!-- Sección Inferior del Menú -->
            <VBox styleClass="md-navbar-button-container">

                <MFXButton fx:id="navbar_settings_button" maxWidth="Infinity" styleClass="md-nav-button"
                           text="Configuración">
                </MFXButton>

                <MFXButton fx:id="navbar_logout_button" maxWidth="Infinity" styleClass="md-nav-button"
                           text="Cerrar Sesión">
                </MFXButton>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox>
            <!-- Header Superior -->
            <HBox styleClass="md-header-bar">
                <VBox styleClass="md-heading-group">
                    <Label styleClass="md-page-title" text="Dashboard"/>
                    <Label styleClass="md-page-subtitle" text="Bienvenido de nuevo"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Contenido Principal -->
            <ScrollPane fitToHeight="true"
                        fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        styleClass="md-content-scroll">
                <VBox styleClass="md-content-section">
                    <!-- Tarjetas de Estadísticas Rápidas -->

                    <GridPane styleClass="md-grid-pane">
                        <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints minHeight="140.0" vgrow="SOMETIMES"/>
                        </rowConstraints>

                        <!-- Tarjeta: Clientes Totales -->
                        <VBox styleClass="md-card" GridPane.columnIndex="0">
                            <HBox styleClass="md-stat-card-container">
                                <Region HBox.hgrow="ALWAYS"/>
                                <VBox>
                                    <Region>
                                        <styleClass>
                                            <String fx:value="md-action-card-icon"/>
                                            <String fx:value="groups-2-icon"/>
                                        </styleClass>
                                    </Region>
                                </VBox>
                            </HBox>
                            <VBox styleClass="md-action-label-container">
                                <Label fx:id="clients_registered_count" styleClass="md-stat-value" text="1,248"/>
                                <Label styleClass="md-stat-label" text="Clientes Registrados"/>
                            </VBox>
                            <HBox styleClass="md-action-label-container">
                                <Label fx:id="clients_registered_percentage_vs_last_month"/>
                                <Label styleClass="md-stat-trend-label" text="vs mes anterior"/>
                            </HBox>
                        </VBox>

                        <!-- Tarjeta: Empleados -->
                        <VBox styleClass="md-card" GridPane.columnIndex="1">
                            <HBox styleClass="md-stat-card-container">
                                <Region HBox.hgrow="ALWAYS"/>
                                <VBox>
                                    <Region>
                                        <styleClass>
                                            <String fx:value="md-action-card-icon"/>
                                            <String fx:value="person-apron-icon"/>
                                        </styleClass>
                                    </Region>
                                </VBox>
                            </HBox>
                            <VBox styleClass="md-action-label-container">
                                <Label fx:id="active_employees_count" styleClass="md-stat-value" text="8"/>
                                <Label styleClass="md-stat-label" text="Empleados Activos"/>
                            </VBox>
                            <HBox styleClass="md-action-label-container">
                                <Label fx:id="active_employees_this_month_count"
                                       text="+2"/>
                                <Label styleClass="md-stat-trend-label" text="este mes"/>
                            </HBox>
                        </VBox>

                        <!-- Tarjeta: Turnos Hoy -->
                        <VBox styleClass="md-card" GridPane.columnIndex="2">
                            <HBox styleClass="md-stat-card-container">
                                <Region HBox.hgrow="ALWAYS"/>
                                <VBox>
                                    <Region>
                                        <styleClass>
                                            <String fx:value="md-action-card-icon"/>
                                            <String fx:value="calendar-today-icon"/>
                                        </styleClass>
                                    </Region>
                                </VBox>
                            </HBox>
                            <VBox styleClass="md-action-label-container">
                                <Label fx:id="appointments_today_count" styleClass="md-stat-value" text="24"/>
                                <Label styleClass="md-stat-label" text="Turnos Hoy"/>
                            </VBox>
                            <HBox styleClass="md-action-label-container">
                                <Label fx:id="finished_appointments_today_count" styleClass="md-stat-trend-neutral"
                                       text="8"/>
                                <Label styleClass="md-stat-trend-label" text="completados"/>
                            </HBox>
                        </VBox>

                        <!-- Tarjeta: Productos en Stock -->
                        <VBox styleClass="md-card" GridPane.columnIndex="3">
                            <HBox styleClass="md-stat-card-container">
                                <Region HBox.hgrow="ALWAYS"/>
                                <VBox>
                                    <Region>
                                        <styleClass>
                                            <String fx:value="md-action-card-icon"/>
                                            <String fx:value="box-icon"/>
                                        </styleClass>
                                    </Region>
                                </VBox>
                            </HBox>
                            <VBox styleClass="md-action-label-container">
                                <Label fx:id="products_on_stock_count" styleClass="md-stat-value" text="156"/>
                                <Label styleClass="md-stat-label" text="Productos en Stock"/>
                            </VBox>
                            <HBox styleClass="md-action-label-container">
                                <Label fx:id="low_stock_products_count" styleClass="md-stat-trend-negative" text="3"/>
                                <Label styleClass="md-stat-trend-label" text="bajo stock"/>
                            </HBox>
                        </VBox>
                    </GridPane>

                    <!-- Sección Principal: Accesos Rápidos -->
                    <VBox styleClass="md-section-group">

                        <Label styleClass="md-section-title" text="Accesos Rápidos"/>

                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="350.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="350.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="180.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="180.0" vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Card: Gestión de Clientes -->
                            <VBox styleClass="md-action-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox alignment="CENTER_LEFT">
                                    <VBox styleClass="md-action-label-container">
                                        <Label styleClass="md-action-title" text="Gestión de Clientes"/>
                                        <Label styleClass="md-action-subtitle"
                                               text="Administra el registro y datos de clientes"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Region>
                                        <styleClass>
                                            <String fx:value="md-action-card-icon"/>
                                            <String fx:value="person-1-icon"/>
                                        </styleClass>
                                    </Region>
                                </HBox>
                                <HBox styleClass="md-action-button-container"
                                      VBox.vgrow="ALWAYS">

                                    <MFXButton fx:id="clients_view_button" styleClass="md-button-outlined"
                                               text="Ver Clientes">
                                    </MFXButton>

                                    <MFXButton fx:id="create_client_button" styleClass="md-button-filled"
                                               text="+ Nuevo Cliente">
                                    </MFXButton>

                                </HBox>
                            </VBox>

                            <!-- Card: Gestión de Empleados -->
                            <VBox styleClass="md-action-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox alignment="CENTER_LEFT">
                                    <VBox styleClass="md-action-label-container">
                                        <Label styleClass="md-action-title" text="Gestión de Empleados"/>
                                        <Label styleClass="md-action-subtitle"
                                               text="Controla horarios, servicios y rendimiento"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Region>
                                        <styleClass>
                                            <String fx:value="md-action-card-icon"/>
                                            <String fx:value="groups-icon"/>
                                        </styleClass>
                                    </Region>
                                </HBox>
                                <HBox styleClass="md-action-button-container"
                                      VBox.vgrow="ALWAYS">

                                    <MFXButton fx:id="employee_view_button" styleClass="md-button-outlined"
                                               text="Ver Empleados">
                                    </MFXButton>

                                    <MFXButton fx:id="create_employee_button" styleClass="md-button-filled"
                                               text="+ Nuevo Empleado">
                                    </MFXButton>

                                </HBox>
                            </VBox>

                            <!-- Card: Gestión de Turnos -->
                            <VBox styleClass="md-action-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <HBox alignment="CENTER_LEFT">
                                    <VBox styleClass="md-action-label-container">
                                        <Label styleClass="md-action-title" text="Gestión de Turnos"/>
                                        <Label styleClass="md-action-subtitle"
                                               text="Organiza y administra los turnos del día"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Region>
                                        <styleClass>
                                            <String fx:value="md-action-card-icon"/>
                                            <String fx:value="calendar-icon"/>
                                        </styleClass>
                                    </Region>
                                </HBox>
                                <HBox styleClass="md-action-button-container"
                                      VBox.vgrow="ALWAYS">

                                    <MFXButton fx:id="appointments_view_button" styleClass="md-button-outlined"
                                               text="Ver Turnos">
                                    </MFXButton>

                                    <MFXButton fx:id="create_appointment_button" styleClass="md-button-filled"
                                               text="+ Nuevo Turno">
                                    </MFXButton>

                                </HBox>
                            </VBox>

                            <!-- Card: Stock de Productos -->
                            <VBox styleClass="md-action-card" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <HBox alignment="CENTER_LEFT">
                                    <VBox styleClass="md-action-label-container">
                                        <Label styleClass="md-action-title" text="Stock de Productos"/>
                                        <Label styleClass="md-action-subtitle"
                                               text="Controla inventario y ventas de productos"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Region>
                                        <styleClass>
                                            <String fx:value="md-action-card-icon"/>
                                            <String fx:value="inventory-1-icon"/>
                                        </styleClass>
                                    </Region>
                                </HBox>
                                <HBox styleClass="md-action-button-container" VBox.vgrow="ALWAYS">

                                    <MFXButton fx:id="products_view_button" styleClass="md-button-outlined"
                                               text="Ver Inventario">
                                    </MFXButton>

                                    <MFXButton fx:id="create_product_button" styleClass="md-button-filled"
                                               text="+ Nuevo Producto">

                                    </MFXButton>

                                </HBox>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- Sección Inferior: Actividad Reciente -->
                    <VBox styleClass="md-section-group">

                        <Label styleClass="md-section-title" text="Actividad Reciente"/>

                        <VBox fx:id="activity_log_vbox" styleClass="md-recent-activity-card"/>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
