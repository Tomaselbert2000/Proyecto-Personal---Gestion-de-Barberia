<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:id="stack_pane"
           xmlns="http://javafx.com/javafx/17.0.12"
           fx:controller="com.launcher.controller.implementation.dashboard.DashboardController">

    <BorderPane fx:id="borderPane" prefHeight="720.0" prefWidth="1200.0">

        <!-- ================================================================= -->
        <!-- NAVIGATION DRAWER (BARRA LATERAL)                                 -->
        <!-- ================================================================= -->
        <left>
            <VBox styleClass="md-navigation-drawer" spacing="16" prefWidth="260.0">
                <padding>
                    <Insets top="16" right="12" bottom="16" left="12"/>
                </padding>

                <!-- Logo y Nombre -->
                <VBox alignment="CENTER" spacing="8">
                    <ImageView fitHeight="64.0" fitWidth="64.0" pickOnBounds="true" preserveRatio="true">
                        <Image url="@../images/Logo.jpg"/>
                    </ImageView>
                    <Label styleClass="md-headline-small" text="LA TERCERA"/>
                    <Label styleClass="md-label-large" text="BARBERSHOP"/>
                </VBox>

                <Separator styleClass="md-nav-divider"/>

                <!-- Menú de Navegación -->
                <VBox spacing="4" VBox.vgrow="ALWAYS">
                    <MFXButton fx:id="navbar_dashboard_button" maxWidth="Infinity"
                               styleClass="md-nav-button, md-nav-button-active" text="Dashboard"/>
                    <MFXButton fx:id="navbar_client_button" maxWidth="Infinity" styleClass="md-nav-button"
                               text="Clientes"/>
                    <MFXButton fx:id="navbar_employee_button" maxWidth="Infinity" styleClass="md-nav-button"
                               text="Empleados"/>
                    <MFXButton fx:id="navbar_appointment_button" maxWidth="Infinity" styleClass="md-nav-button"
                               text="Turnos"/>
                    <MFXButton fx:id="navbar_barber_service_button" maxWidth="Infinity" styleClass="md-nav-button"
                               text="Servicios"/>
                    <MFXButton fx:id="navbar_product_button" maxWidth="Infinity" styleClass="md-nav-button"
                               text="Stock de productos"/>
                    <MFXButton fx:id="navbar_payment_button" maxWidth="Infinity" styleClass="md-nav-button"
                               text="Medios de pago"/>
                </VBox>

                <Separator styleClass="md-nav-divider"/>

                <!-- Sección Inferior -->
                <VBox spacing="4">
                    <MFXButton fx:id="navbar_settings_button" maxWidth="Infinity" styleClass="md-nav-button"
                               text="Configuración"/>
                    <MFXButton fx:id="navbar_logout_button" maxWidth="Infinity" styleClass="md-nav-button"
                               text="Cerrar Sesión"/>
                </VBox>
            </VBox>
        </left>

        <!-- ================================================================= -->
        <!-- CONTENIDO PRINCIPAL                                               -->
        <!-- ================================================================= -->
        <center>
            <VBox>
                <!-- Header Superior -->
                <HBox alignment="CENTER_LEFT" styleClass="md-surface">
                    <padding>
                        <Insets top="20" right="24" bottom="12" left="24"/>
                    </padding>
                    <VBox spacing="2">
                        <Label styleClass="md-headline-medium" text="Dashboard"/>
                        <Label styleClass="md-body-large" text="Bienvenido de nuevo"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Área Escroleable -->
                <ScrollPane fitToHeight="true" fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                    <VBox spacing="24">
                        <padding>
                            <Insets top="16" right="24" bottom="24" left="24"/>
                        </padding>

                        <!-- 1. TARJETAS DE ESTADÍSTICAS RÁPIDAS -->
                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                            </columnConstraints>

                            <!-- Tarjeta 1: Clientes Registrados -->
                            <VBox styleClass="md-card" spacing="12" GridPane.columnIndex="0">
                                <padding>
                                    <Insets top="16" right="16" bottom="16" left="16"/>
                                </padding>
                                <HBox alignment="CENTER_LEFT">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label fx:id="clients_registered_count" styleClass="md-headline-large"
                                               text="0"/>
                                        <Label styleClass="md-body-medium" text="Clientes Registrados"/>
                                    </VBox>
                                    <!-- Tu clase SVG groups-2-icon -->
                                    <Region styleClass="groups-2-icon, md-icon-large, md-icon-primary"/>
                                </HBox>
                                <HBox spacing="4" alignment="CENTER_LEFT">
                                    <Label fx:id="clients_registered_percentage_vs_last_month"
                                           styleClass="md-label-medium" text="0.0%"/>
                                    <Label styleClass="md-label-small" text="vs mes anterior"/>
                                </HBox>
                            </VBox>

                            <!-- Tarjeta 2: Empleados -->
                            <VBox styleClass="md-card" spacing="12" GridPane.columnIndex="1">
                                <padding>
                                    <Insets top="16" right="16" bottom="16" left="16"/>
                                </padding>
                                <HBox alignment="CENTER_LEFT">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label fx:id="active_employees_count" styleClass="md-headline-large"
                                               text="0"/>
                                        <Label styleClass="md-body-medium" text="Empleados Activos"/>
                                    </VBox>
                                    <!-- Tu clase SVG person-apron-icon -->
                                    <Region styleClass="person-apron-icon, md-icon-large, md-icon-primary"/>
                                </HBox>
                                <HBox spacing="4" alignment="CENTER_LEFT">
                                    <Label fx:id="active_employees_this_month_count" styleClass="md-label-medium"
                                           text="0"/>
                                    <Label styleClass="md-label-small" text="este mes"/>
                                </HBox>
                            </VBox>

                            <!-- Tarjeta 3: Turnos Hoy -->
                            <VBox styleClass="md-card" spacing="12" GridPane.columnIndex="2">
                                <padding>
                                    <Insets top="16" right="16" bottom="16" left="16"/>
                                </padding>
                                <HBox alignment="CENTER_LEFT">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label fx:id="appointments_today_count" styleClass="md-headline-large"
                                               text="0"/>
                                        <Label styleClass="md-body-medium" text="Turnos Hoy"/>
                                    </VBox>
                                    <!-- Tu clase SVG calendar-today-icon -->
                                    <Region styleClass="calendar-today-icon, md-icon-large, md-icon-primary"/>
                                </HBox>
                                <HBox spacing="4" alignment="CENTER_LEFT">
                                    <Label fx:id="finished_appointments_today_count" styleClass="md-label-medium"
                                           text="0"/>
                                    <Label styleClass="md-label-small" text="completados"/>
                                </HBox>
                            </VBox>

                            <!-- Tarjeta 4: Productos en Stock -->
                            <VBox styleClass="md-card" spacing="12" GridPane.columnIndex="3">
                                <padding>
                                    <Insets top="16" right="16" bottom="16" left="16"/>
                                </padding>
                                <HBox alignment="CENTER_LEFT">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label fx:id="products_on_stock_count" styleClass="md-headline-large"
                                               text="0"/>
                                        <Label styleClass="md-body-medium" text="Productos en Stock"/>
                                    </VBox>
                                    <!-- Tu clase SVG box-icon -->
                                    <Region styleClass="box-icon, md-icon-large, md-icon-primary"/>
                                </HBox>
                                <HBox spacing="4" alignment="CENTER_LEFT">
                                    <Label fx:id="low_stock_products_count" styleClass="md-label-medium" text="0"/>
                                    <Label styleClass="md-label-small" text="bajo stock"/>
                                </HBox>
                            </VBox>
                        </GridPane>

                        <!-- 2. ACCESOS RÁPIDOS -->
                        <VBox spacing="12">
                            <Label styleClass="md-title-medium" text="Accesos Rápidos"/>

                            <GridPane hgap="16" vgap="16">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                </columnConstraints>

                                <!-- Card: Gestión de Clientes -->
                                <VBox styleClass="md-action-card" spacing="16" GridPane.columnIndex="0"
                                      GridPane.rowIndex="0">
                                    <padding>
                                        <Insets top="20" right="20" bottom="20" left="20"/>
                                    </padding>
                                    <HBox>
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <Label styleClass="md-title-large" text="Gestión de Clientes"/>
                                            <Label styleClass="md-body-small"
                                                   text="Administra el registro y datos de clientes"/>
                                        </VBox>
                                        <!-- Tu clase SVG person-1-icon -->
                                        <Region styleClass="person-1-icon, md-icon-medium"/>
                                    </HBox>
                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <MFXButton fx:id="clients_view_button" styleClass="md-button-outlined"
                                                   text="Ver Clientes"/>
                                        <MFXButton fx:id="create_client_button" styleClass="md-button-filled"
                                                   text="+ Nuevo Cliente"/>
                                    </HBox>
                                </VBox>

                                <!-- Card: Gestión de Empleados -->
                                <VBox styleClass="md-action-card" spacing="16" GridPane.columnIndex="1"
                                      GridPane.rowIndex="0">
                                    <padding>
                                        <Insets top="20" right="20" bottom="20" left="20"/>
                                    </padding>
                                    <HBox>
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <Label styleClass="md-title-large" text="Gestión de Empleados"/>
                                            <Label styleClass="md-body-small"
                                                   text="Controla horarios, servicios y rendimiento"/>
                                        </VBox>
                                        <!-- Tu clase SVG groups-icon -->
                                        <Region styleClass="groups-icon, md-icon-medium"/>
                                    </HBox>
                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <MFXButton fx:id="employee_view_button" styleClass="md-button-outlined"
                                                   text="Ver Empleados"/>
                                        <MFXButton fx:id="create_employee_button" styleClass="md-button-filled"
                                                   text="+ Nuevo Empleado"/>
                                    </HBox>
                                </VBox>

                                <!-- Card: Gestión de Turnos -->
                                <VBox styleClass="md-action-card" spacing="16" GridPane.columnIndex="0"
                                      GridPane.rowIndex="1">
                                    <padding>
                                        <Insets top="20" right="20" bottom="20" left="20"/>
                                    </padding>
                                    <HBox>
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <Label styleClass="md-title-large" text="Gestión de Turnos"/>
                                            <Label styleClass="md-body-small"
                                                   text="Organiza y administra los turnos del día"/>
                                        </VBox>
                                        <!-- Tu clase SVG calendar-icon -->
                                        <Region styleClass="calendar-icon, md-icon-medium"/>
                                    </HBox>
                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <MFXButton fx:id="appointments_view_button" styleClass="md-button-outlined"
                                                   text="Ver Turnos"/>
                                        <MFXButton fx:id="create_appointment_button" styleClass="md-button-filled"
                                                   text="+ Nuevo Turno"/>
                                    </HBox>
                                </VBox>

                                <!-- Card: Stock de Productos -->
                                <VBox styleClass="md-action-card" spacing="16" GridPane.columnIndex="1"
                                      GridPane.rowIndex="1">
                                    <padding>
                                        <Insets top="20" right="20" bottom="20" left="20"/>
                                    </padding>
                                    <HBox>
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <Label styleClass="md-title-large" text="Stock de Productos"/>
                                            <Label styleClass="md-body-small"
                                                   text="Controla inventario y ventas de productos"/>
                                        </VBox>
                                        <!-- Tu clase SVG inventory-1-icon -->
                                        <Region styleClass="inventory-1-icon, md-icon-medium"/>
                                    </HBox>
                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <MFXButton fx:id="products_view_button" styleClass="md-button-outlined"
                                                   text="Ver Inventario"/>
                                        <MFXButton fx:id="create_product_button" styleClass="md-button-filled"
                                                   text="+ Nuevo Producto"/>
                                    </HBox>
                                </VBox>
                            </GridPane>
                        </VBox>

                        <!-- 3. ACTIVIDAD RECIENTE -->
                        <VBox spacing="12">
                            <Label styleClass="md-title-medium" text="Actividad Reciente"/>
                            <VBox fx:id="activity_log_vbox" styleClass="md-card">
                                <padding>
                                    <Insets top="16" right="16" bottom="16" left="16"/>
                                </padding>
                            </VBox>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </VBox>
        </center>
    </BorderPane>
</StackPane>