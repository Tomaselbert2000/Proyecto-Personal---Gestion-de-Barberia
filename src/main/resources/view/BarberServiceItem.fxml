<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.barbershop.launcher.controller.barberservice.BarberServiceItemController">

    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="service-card">

        <!-- Service Icon -->
        <VBox styleClass="service-icon-container">
            <Region prefHeight="24.0" prefWidth="24.0" styleClass="navbar-icon-services" />
        </VBox>

        <!-- Service Information -->
        <VBox alignment="CENTER_LEFT" spacing="4.0" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label fx:id="service_name" styleClass="service-name">
                    <font>
                        <Font name="Roboto Medium" size="16.0" />
                    </font>
                </Label>
                <VBox styleClass="category-badge-corte">
                    <Label fx:id="category_text" styleClass="category-badge-text">
                        <font>
                            <Font name="Roboto Bold" size="16.0" />
                        </font>
                    </Label>
                </VBox>
            </HBox>
        </VBox>

        <!-- Price -->
        <VBox alignment="CENTER" minWidth="100.0" styleClass="price-container">
            <Label fx:id="service_price" styleClass="service-price">
                <font>
                    <Font name="Roboto Bold" size="20.0" />
                </font>
            </Label>
        </VBox>

        <!-- Actions -->
        <HBox alignment="CENTER" spacing="8.0">
            <Button fx:id="edit_button" mnemonicParsing="false" styleClass="appointment-action-button" text="Editar">
                <font>
                    <Font name="Roboto Medium" size="12.0" />
                </font>
            </Button>
            <Button fx:id="delete_button" mnemonicParsing="false" styleClass="appointment-action-button-cancel" text="Eliminar">
                <font>
                    <Font name="Roboto Medium" size="12.0" />
                </font>
            </Button>
        </HBox>
    </HBox>

</VBox>
