<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="anchor_pane"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="com.launcher.controller.implementation.employee.EmployeeEditionController">

    <VBox
            AnchorPane.topAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0"
            AnchorPane.bottomAnchor="0.0">

        <!-- Header del Panel -->
        <HBox styleClass="md-header-bar">
            <MFXButton fx:id="back_button" styleClass="md-button-filled-tonal" text="← Volver"/>
            <VBox styleClass="md-section-group">
                <Label styleClass="md-page-title" text="Editar Empleado"/>
            </VBox>
        </HBox>

        <!-- Contenido Principal -->
        <ScrollPane fitToHeight="true"
                    fitToWidth="true"
                    styleClass="md-content-scroll"
                    VBox.vgrow="ALWAYS">
            <VBox styleClass="md-content-section">

                <!-- Tarjeta de Información Actual -->
                <VBox styleClass="md-card">
                    <VBox styleClass="md-section-group">
                        <Label styleClass="md-section-title" text="Información Actual"/>

                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="60.0" vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- Current Name (Read-only) -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Nombre Actual"/>
                                </HBox>
                                <Label fx:id="current_first_name" styleClass="md-filter-label"/>
                            </VBox>

                            <!-- Current Last Name (Read-only) -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Apellido Actual"/>
                                </HBox>
                                <Label fx:id="current_last_name" styleClass="md-filter-label"/>
                            </VBox>

                            <!-- Current Hire Date (Read-only) -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Fecha de Contratación"/>
                                </HBox>
                                <Label fx:id="current_hire_date" styleClass="md-filter-label"/>
                            </VBox>

                            <!-- Current Commission (Read-only) -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Comisión Actual"/>
                                </HBox>
                                <Label fx:id="current_commission" styleClass="md-filter-label"/>
                            </VBox>

                            <!-- Current Status (Read-only) -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Estado Actual"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <Label fx:id="current_status_label" styleClass="md-filter-label"/>
                                </HBox>
                            </VBox>

                            <!-- Termination Date (Read-only if exists) -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Fecha de Baja"/>
                                </HBox>
                                <Label fx:id="current_termination_date" styleClass="md-filter-label"/>
                            </VBox>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Tarjeta de Cambiar Datos -->
                <VBox styleClass="md-card">
                    <VBox styleClass="md-section-group">
                        <Label styleClass="md-section-title" text="Cambiar Datos"/>

                        <GridPane styleClass="md-grid-pane">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints vgrow="SOMETIMES"/>
                                <RowConstraints vgrow="SOMETIMES"/>
                                <RowConstraints vgrow="SOMETIMES"/>
                            </rowConstraints>

                            <!-- New First Name -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Nuevo Nombre"/>
                                </HBox>
                                <TextField fx:id="first_name_field" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- New Last Name -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Nuevo Apellido"/>
                                </HBox>
                                <TextField fx:id="last_name_field" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- New Commission Percentage -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Nueva Comisión (%)"/>
                                </HBox>
                                <TextField fx:id="commission_field" styleClass="md-text-field" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Status Toggle -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Cambiar Estado"/>
                                </HBox>
                                <HBox styleClass="md-action-button-container">
                                    <MFXButton fx:id="toggle_status_button" styleClass="md-button-filled-tonal"
                                               text="Desactivar"/>
                                </HBox>
                            </VBox>

                            <!-- Termination Date (Optional) -->
                            <VBox styleClass="md-filter-column" GridPane.columnIndex="0" GridPane.columnSpan="2"
                                  GridPane.rowIndex="2">
                                <HBox styleClass="md-filter-spacer">
                                    <Label styleClass="md-filter-label" text="Fecha de Baja (Opcional)"/>
                                </HBox>
                                <DatePicker fx:id="termination_date_picker" styleClass="md-date-picker"/>
                            </VBox>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Botones de Acción -->
                <HBox styleClass="md-action-button-container">
                    <MFXButton fx:id="reset_button" styleClass="md-button-filled-tonal" text="Restaurar datos"/>
                    <MFXButton fx:id="save_button" styleClass="md-button-filled" text="Actualizar Empleado"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
